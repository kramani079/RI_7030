@{
    ViewData["Title"] = "Transactions";
    var activeTab = ViewBag.Tab as string ?? "buy";
    var isAdmin   = Context.Session.GetString("Role") == "Admin";
    var search    = ViewBag.Search as string ?? "";
    var nextId    = ViewBag.NextId as string ?? "";
    var products  = ViewBag.Products as List<RI_7030.Models.Product> ?? new();
    var history   = ViewBag.History  as List<RI_7030.Models.Transaction> ?? new();
    var duePay    = ViewBag.DuePayments as List<RI_7030.Models.Transaction> ?? new();
    var T  = ViewBag.T as Dictionary<string, string> ?? new();
    string Tr(string k) => T.TryGetValue(k, out var v) ? v : k;
}

<style>
    .tab-bar { display:flex; gap:0; border-bottom:2px solid #e4e9f0; margin-bottom:28px; }
    .tab-btn { padding:11px 28px; font-size:14px; font-weight:600; color:#888; background:none; border:none; border-bottom:3px solid transparent; margin-bottom:-2px; cursor:pointer; transition:color .2s,border-color .2s; text-decoration:none; }
    .tab-btn:hover { color:#2b8bbd; } .tab-btn.active { color:#2b8bbd; border-bottom-color:#2b8bbd; }
    .form-title { font-size:17px; font-weight:700; color:#1a1a2e; margin-bottom:22px; }
    .tx-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:18px 24px; margin-bottom:20px; }
    @@media (max-width:800px) { .tx-grid { grid-template-columns:1fr 1fr; } }
    .fg { display:flex; flex-direction:column; }
    .fg label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:#999; margin-bottom:5px; }
    .fg input, .fg select { padding:9px 13px; border:1.5px solid #dde1e7; border-radius:8px; font-size:13px; font-family:'Inter',sans-serif; background:#f8f9fb; color:#333; outline:none; transition:border-color .2s; }
    .fg input:focus, .fg select:focus { border-color:#2b8bbd; background:#fff; }
    .fg input[readonly] { background:#eef5fa; color:#2b8bbd; font-weight:600; }
    .form-footer { display:flex; justify-content:flex-end; margin-top:6px; }
    .btn-submit { background:linear-gradient(135deg,#2b8bbd,#1a6d99); color:#fff; border:none; padding:11px 38px; border-radius:8px; font-size:14px; font-weight:700; cursor:pointer; box-shadow:0 3px 12px rgba(43,139,189,.25); transition:all .2s; }
    .btn-submit:hover { transform:translateY(-1px); }
    .hist-search { width:100%; padding:9px 14px; border:1.5px solid #e0e6ed; border-radius:8px; font-size:13px; background:#f8f9fb; outline:none; margin-bottom:18px; }
    .hist-table { width:100%; border-collapse:collapse; font-size:13px; }
    .hist-table thead th { background:#f4f7fb; padding:11px 14px; text-align:left; font-weight:700; color:#666; border-bottom:2px solid #e4e9f0; font-size:11px; text-transform:uppercase; letter-spacing:.4px; }
    .hist-table tbody td { padding:12px 14px; border-bottom:1px solid #f2f4f7; color:#333; vertical-align:middle; }
    .hist-table tbody tr:hover { background:#f7fafd; }
    .bdg { display:inline-block; padding:3px 11px; border-radius:20px; font-size:11px; font-weight:700; }
    .bdg-buy { background:#e8f4fd; color:#2980b9; } .bdg-sell { background:#eafaf1; color:#1e8449; }
    .bdg-received { background:#d1f5e0; color:#155724; } .bdg-pending { background:#fff8e1; color:#856404; }
    .bdg-paid { background:#e8f4fd; color:#0c5460; } .bdg-cancelled { background:#fdecea; color:#842029; }
    .action-btn-sm { padding:4px 12px; border-radius:6px; font-size:11px; font-weight:600; border:none; cursor:pointer; text-decoration:none; display:inline-block; }
    .btn-edit-sm { background:#f4f6fb; color:#555; border:1.5px solid #e0e6ed; }
    .btn-pay-sm  { background:#eafaf1; color:#1e8449; margin-left:4px; }
    .btn-recv-sm { background:#e8f4fd; color:#2980b9; margin-left:4px; }
    .empty-state { text-align:center; color:#bbb; padding:30px; }
    .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:200; align-items:center; justify-content:center; }
    .modal-overlay.open { display:flex; }
    .modal-box { background:#fff; border-radius:16px; padding:32px 36px; width:100%; max-width:500px; box-shadow:0 12px 48px rgba(0,0,0,.18); animation:slideUp .2s ease; }
    @@keyframes slideUp { from { transform:translateY(20px); opacity:0; } to { transform:translateY(0); opacity:1; } }
    .modal-title { font-size:17px; font-weight:800; color:#1a1a2e; margin-bottom:24px; display:flex; align-items:center; justify-content:space-between; }
    .modal-close { background:none; border:none; font-size:20px; color:#999; cursor:pointer; }
    .mfg { margin-bottom:16px; }
    .mfg label { display:block; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:#999; margin-bottom:5px; }
    .mfg input, .mfg select { width:100%; padding:10px 14px; border:1.5px solid #dde1e7; border-radius:8px; font-size:13px; font-family:'Inter',sans-serif; background:#f8f9fb; color:#333; outline:none; box-sizing:border-box; }
    .modal-footer { display:flex; justify-content:flex-end; gap:12px; margin-top:24px; }
    .btn-cancel { padding:9px 24px; border-radius:8px; font-size:13px; font-weight:600; background:#fff; color:#555; border:1.5px solid #dde1e7; cursor:pointer; font-family:'Inter',sans-serif; }
    .btn-update { padding:9px 28px; border-radius:8px; font-size:13px; font-weight:700; background:linear-gradient(135deg,#2b8bbd,#1a6d99); color:#fff; border:none; cursor:pointer; font-family:'Inter',sans-serif; }
</style>

<div class="card-box">
    <div class="tab-bar">
        <a href="/Transaction?tab=buy"     class="tab-btn @(activeTab=="buy"     ? "active" : "")">@Tr("buy")</a>
        <a href="/Transaction?tab=sell"    class="tab-btn @(activeTab=="sell"    ? "active" : "")">@Tr("sell")</a>
        <a href="/Transaction?tab=history" class="tab-btn @(activeTab=="history" ? "active" : "")">@Tr("history")</a>
        @if (isAdmin)
        {
            <a href="/Transaction?tab=due" class="tab-btn @(activeTab=="due" ? "active" : "")">@Tr("due_payments")</a>
        }
    </div>

    @if (activeTab == "buy")
    {
        <div class="form-title">@Tr("new_purchase")</div>
        <form method="post" action="/Transaction/Buy">
            @Html.AntiForgeryToken()
            <div class="tx-grid">
                <div class="fg"><label>@Tr("tx_id_auto")</label><input type="text" value="@nextId" readonly /></div>
                <div class="fg"><label>@Tr("product")</label>
                    <select name="productId">
                        <option value="">@Tr("select_product_opt")</option>
                        @foreach (var p in products) { <option value="@p.ProductId">@p.ProductId – @p.Name</option> }
                    </select>
                </div>
                <div class="fg"><label>@Tr("quantity")</label><input name="quantity" type="number" min="1" /></div>
                <div class="fg"><label>@Tr("from_supplier")</label><input name="partyName" type="text" required /></div>
                <div class="fg"><label>@Tr("amount") (₹)</label><input name="amount" type="number" min="0" step="0.01" required /></div>
                <div class="fg"><label>@Tr("category")</label>
                    <select name="category">
                        <option value="PRODUCT">@Tr("product_purchase")</option>
                        <option value="EXPENSE">@Tr("expense")</option>
                        <option value="EMP_SALARY">@Tr("emp_salary")</option>
                    </select>
                </div>
                <div class="fg"><label>@Tr("payment_method")</label>
                    <select name="paymentMethod">
                        <option value="">@Tr("pending_not_paid")</option>
                        <option value="Cash">@Tr("cash_paid")</option>
                        <option value="Bank Transfer">@Tr("bank_paid")</option>
                        <option value="UPI">@Tr("upi_paid")</option>
                    </select>
                </div>
            </div>
            <div class="form-footer"><button type="submit" class="btn-submit">@Tr("complete_purchase")</button></div>
        </form>
    }

    @if (activeTab == "sell")
    {
        <div class="form-title">@Tr("new_sale")</div>
        <form method="post" action="/Transaction/Sell">
            @Html.AntiForgeryToken()
            <div class="tx-grid">
                <div class="fg"><label>@Tr("tx_id_auto")</label><input type="text" value="@nextId" readonly /></div>
                <div class="fg"><label>@Tr("product")</label>
                    <select name="productId">
                        <option value="">@Tr("select_product_opt")</option>
                        @foreach (var p in products) { <option value="@p.ProductId">@p.ProductId – @p.Name (@Tr("stock"): @p.Stock)</option> }
                    </select>
                </div>
                <div class="fg"><label>@Tr("quantity")</label><input name="quantity" type="number" min="1" required /></div>
                <div class="fg"><label>@Tr("to_customer")</label><input name="partyName" type="text" required /></div>
                <div class="fg"><label>@Tr("amount") (₹)</label><input name="amount" type="number" min="0" step="0.01" required /></div>
                <div class="fg"><label>@Tr("payment_method")</label>
                    <select name="paymentMethod">
                        <option value="">@Tr("pending_not_recv")</option>
                        <option value="Cash">@Tr("cash_recv")</option>
                        <option value="Bank Transfer">@Tr("bank_recv")</option>
                        <option value="UPI">@Tr("upi_recv")</option>
                    </select>
                </div>
            </div>
            <div class="form-footer"><button type="submit" class="btn-submit">@Tr("complete_sale")</button></div>
        </form>
    }

    @if (activeTab == "history")
    {
        <div class="form-title">@Tr("tx_history")</div>
        <form method="get">
            <input type="hidden" name="tab" value="history" />
            <input type="text" name="search" value="@search" class="hist-search" placeholder="@Tr("search_tx")" />
        </form>
        @if (!history.Any())
        {
            <div class="empty-state">@Tr("no_tx")</div>
        }
        else
        {
            <table class="hist-table">
                <thead>
                    <tr><th>@Tr("tx_id")</th><th>@Tr("type")</th><th>@Tr("party")</th><th>@Tr("product")</th><th>@Tr("qty")</th><th>@Tr("amount")</th><th>@Tr("status")</th><th>@Tr("date")</th><th>@Tr("actions")</th></tr>
                </thead>
                <tbody>
                    @foreach (var tx in history)
                    {
                        <tr>
                            <td><strong>@tx.TransactionId</strong></td>
                            <td><span class="bdg @(tx.Type == "Sell" ? "bdg-sell" : "bdg-buy")">@tx.Type</span></td>
                            <td>@(tx.PartyName ?? "—")</td>
                            <td>@(tx.ProductName ?? tx.Category ?? "—") @if (tx.ProductId != null) { <div style="font-size:11px;color:#2b8bbd;font-weight:600;">@tx.ProductId</div> }</td>
                            <td>@tx.Quantity</td>
                            <td style="font-weight:700;color:@(tx.Type == "Sell" ? "#27ae60" : "#e74c3c")">@(tx.Type == "Sell" ? "+" : "−")₹@tx.Amount.ToString("N0")</td>
                            <td>
                                @{ var bdgCls = tx.Status switch { "Received" => "bdg-received", "Paid" => "bdg-paid", "Cancelled" => "bdg-cancelled", _ => "bdg-pending" }; }
                                <span class="bdg @bdgCls">@tx.Status</span>
                            </td>
                            <td>@tx.TransactionDate.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (isAdmin)
                                {
                                    <button class="action-btn-sm btn-edit-sm" onclick="openEdit('@tx.TransactionId','@(tx.PartyName ?? "")','@tx.Amount','@tx.Status','@(tx.PaymentMethod ?? "")')">@Tr("edit")</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }

    @if (activeTab == "due" && isAdmin)
    {
        <div class="form-title">@Tr("due_title")</div>
        @if (!duePay.Any())
        {
            <div class="empty-state">@Tr("no_due")</div>
        }
        else
        {
            <table class="hist-table">
                <thead>
                    <tr><th>@Tr("tx_id")</th><th>@Tr("type")</th><th>@Tr("party")</th><th>@Tr("amount")</th><th>@Tr("category")</th><th>@Tr("date")</th><th>@Tr("actions")</th></tr>
                </thead>
                <tbody>
                    @foreach (var tx in duePay)
                    {
                        <tr>
                            <td><strong>@tx.TransactionId</strong></td>
                            <td><span class="bdg @(tx.Type == "Sell" ? "bdg-sell" : "bdg-buy")">@tx.Type</span></td>
                            <td>@(tx.PartyName ?? "—")</td>
                            <td style="font-weight:700;">₹@tx.Amount.ToString("N0")</td>
                            <td>@(tx.Category ?? "—")</td>
                            <td>@tx.TransactionDate.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (tx.Type == "Buy")
                                {
                                    <form method="post" action="/Transaction/PayNow/@tx.TransactionId" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="action-btn-sm btn-pay-sm">@Tr("pay_now")</button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" action="/Transaction/MarkReceived/@tx.TransactionId" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="action-btn-sm btn-recv-sm">@Tr("mark_received")</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }
</div>

<!-- Edit Modal -->
@if (isAdmin)
{
    <div class="modal-overlay" id="editModal">
        <div class="modal-box">
            <div class="modal-title">
                <span id="editModalTitle">@Tr("edit_tx")</span>
                <button class="modal-close" onclick="closeEdit()">×</button>
            </div>
            <form method="post" id="editTxForm">
                @Html.AntiForgeryToken()
                <div class="mfg"><label>@Tr("party_name")</label><input name="partyName" id="mParty" type="text" /></div>
                <div class="mfg"><label>@Tr("amount") (₹)</label><input name="amount" id="mAmount" type="number" step="0.01" /></div>
                <div class="mfg"><label>@Tr("status")</label>
                    <select name="status" id="mStatus">
                        <option value="Pending">@Tr("s_pending")</option>
                        <option value="Paid">@Tr("s_paid")</option>
                        <option value="Received">@Tr("s_received")</option>
                        <option value="Cancelled">@Tr("s_cancelled")</option>
                    </select>
                </div>
                <div class="mfg"><label>@Tr("payment_method")</label>
                    <select name="paymentMethod" id="mPayment">
                        <option value="">@Tr("not_specified")</option>
                        <option value="Cash">@Tr("cash")</option>
                        <option value="Bank Transfer">@Tr("bank_transfer")</option>
                        <option value="UPI">UPI</option>
                    </select>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-cancel" onclick="closeEdit()">@Tr("cancel")</button>
                    <button type="submit" class="btn-update">@Tr("update")</button>
                </div>
            </form>
        </div>
    </div>
}

<script>
    function openEdit(txId, party, amount, status, payment) {
        document.getElementById('editModalTitle').textContent = '@Tr("edit_tx"): ' + txId;
        document.getElementById('editTxForm').action = '/Transaction/Edit/' + txId;
        document.getElementById('mParty').value = party;
        document.getElementById('mAmount').value = amount;
        document.getElementById('mStatus').value = status;
        const payEl = document.getElementById('mPayment');
        if (payEl) payEl.value = payment;
        document.getElementById('editModal').classList.add('open');
    }
    function closeEdit() { document.getElementById('editModal').classList.remove('open'); }
    document.querySelectorAll('.modal-overlay').forEach(el => {
        el.addEventListener('click', e => { if (e.target === el) el.classList.remove('open'); });
    });
</script>
