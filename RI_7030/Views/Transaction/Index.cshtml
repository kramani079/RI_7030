@{
    ViewData["Title"] = "Transactions";
    var activeTab = ViewBag.Tab ?? "buy";
}

<style>
    /* Tabs */
    .tab-bar {
        display: flex;
        gap: 0;
        border-bottom: 2px solid #e0e6ed;
        margin-bottom: 22px;
    }
    .tab-btn {
        padding: 10px 28px;
        font-size: 14px;
        font-weight: 600;
        color: #777;
        background: none;
        border: none;
        border-bottom: 3px solid transparent;
        margin-bottom: -2px;
        cursor: pointer;
        transition: color .2s, border-color .2s;
        text-decoration: none;
    }
    .tab-btn:hover { color: #4a8dac; }
    .tab-btn.active { color: #4a8dac; border-bottom-color: #4a8dac; }

    /* Two-column form layout */
    .tx-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }
    .tx-col h6 {
        font-size: 13px;
        font-weight: 700;
        color: #555;
        margin-bottom: 14px;
        text-transform: uppercase;
        letter-spacing: .5px;
    }
    .form-group { margin-bottom: 14px; }
    .form-group label {
        display: block;
        font-size: 11px;
        font-weight: 700;
        color: #888;
        text-transform: uppercase;
        letter-spacing: .4px;
        margin-bottom: 5px;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
        width: 100%;
        padding: 9px 13px;
        border: 1px solid #dde1e7;
        border-radius: 8px;
        font-size: 13px;
        background: #f9f9fb;
        color: #333;
        outline: none;
        box-sizing: border-box;
        transition: border-color .2s;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus { border-color: #4a8dac; background: #fff; }
    .form-group textarea { resize: vertical; min-height: 72px; }

    .form-footer {
        display: flex;
        justify-content: flex-end;
        margin-top: 20px;
    }
    .btn-submit {
        background: #4a8dac; color: #fff; border: none;
        padding: 11px 36px; border-radius: 8px;
        font-size: 14px; font-weight: 700; cursor: pointer;
    }
    .btn-submit:hover { background: #3a7a98; }

    /* History table */
    .hist-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .hist-table thead th {
        background: #f0f4f8; padding: 10px 14px; text-align: left;
        font-weight: 700; color: #555; border-bottom: 2px solid #e0e6ed;
    }
    .hist-table tbody td {
        padding: 11px 14px; border-bottom: 1px solid #f0f0f0; color: #333;
    }
    .hist-table tbody tr:hover { background: #f7fafc; }

    .badge-type-buy  { background: #e8f4fd; color: #2980b9; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .badge-type-sell { background: #eafaf1; color: #1e8449; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }

    .badge-s-paid     { background: #d1f5e0; color: #155724; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .badge-s-pending  { background: #fff8e1; color: #856404; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .badge-s-cancelled{ background: #fdecea; color: #842029; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }

    @@media (max-width: 700px) { .tx-layout { grid-template-columns: 1fr; } }
</style>

<div class="card-box">

    <!-- Tab bar -->
    <div class="tab-bar">
        <a href="/Transaction?tab=buy"     class="tab-btn @(activeTab=="buy"     ? "active" : "")">🛒 Buy</a>
        <a href="/Transaction?tab=sell"    class="tab-btn @(activeTab=="sell"    ? "active" : "")">💰 Sell</a>
        <a href="/Transaction?tab=history" class="tab-btn @(activeTab=="history" ? "active" : "")">📋 History</a>
    </div>

    <!-- BUY Tab -->
    @if (activeTab == "buy")
    {
        <h5 style="font-size:16px;font-weight:700;color:#1a1a2e;margin-bottom:20px;">Transaction Form — Buy</h5>
        <form method="post" action="/Transaction/Create">
            @Html.AntiForgeryToken()
            <input type="hidden" name="TransactionType" value="Buy" />
            <div class="tx-layout">
                <div class="tx-col">
                    <h6>Supplier</h6>
                    <div class="form-group">
                        <label>Supplier Name</label>
                        <input type="text" name="CustomerName" placeholder="e.g. Nikhil Supplier" />
                    </div>
                    <div class="form-group">
                        <label>Supplier Email</label>
                        <input type="email" name="CustomerEmail" placeholder="e.g. nikhil@supplier.com" />
                    </div>
                    <div class="form-group">
                        <label>Payment Method</label>
                        <select name="PaymentMethod">
                            <option value="Cash">Cash</option>
                            <option value="BankTransfer">Bank Transfer</option>
                            <option value="Online">Online</option>
                            <option value="CreditCard">Credit Card</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Notes</label>
                        <textarea name="Notes" placeholder="Optional notes…"></textarea>
                    </div>
                </div>
                <div class="tx-col">
                    <h6>Product</h6>
                    <div class="form-group">
                        <label>Product</label>
                        <select name="ItemName">
                            <option value="" disabled selected>Select product…</option>
                            <option>Gold Ring</option>
                            <option>Gold Chain</option>
                            <option>Diamond Necklace</option>
                            <option>Gold Bangle</option>
                            <option>Silver Earrings</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Quantity</label>
                        <input type="number" name="Quantity" placeholder="e.g. 50" min="1" />
                    </div>
                    <div class="form-group">
                        <label>Unit Price (₹)</label>
                        <input type="number" name="UnitPrice" placeholder="e.g. 5000" min="0" />
                    </div>
                    <div class="form-group">
                        <label>Transaction Date</label>
                        <input type="date" name="TransactionDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                </div>
            </div>
            <div class="form-footer">
                <button type="submit" class="btn-submit">Submit Purchase</button>
            </div>
        </form>
    }

    <!-- SELL Tab -->
    @if (activeTab == "sell")
    {
        <h5 style="font-size:16px;font-weight:700;color:#1a1a2e;margin-bottom:20px;">Transaction Form — Sell</h5>
        <form method="post" action="/Transaction/Create">
            @Html.AntiForgeryToken()
            <input type="hidden" name="TransactionType" value="Sell" />
            <div class="tx-layout">
                <div class="tx-col">
                    <h6>Customer</h6>
                    <div class="form-group">
                        <label>Customer Name</label>
                        <input type="text" name="CustomerName" placeholder="e.g. Mahesh Patel" />
                    </div>
                    <div class="form-group">
                        <label>Customer Email</label>
                        <input type="email" name="CustomerEmail" placeholder="e.g. mahesh@gmail.com" />
                    </div>
                    <div class="form-group">
                        <label>Payment Method</label>
                        <select name="PaymentMethod">
                            <option value="Cash">Cash</option>
                            <option value="BankTransfer">Bank Transfer</option>
                            <option value="Online">Online</option>
                            <option value="DebitCard">Debit Card</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Notes</label>
                        <textarea name="Notes" placeholder="Optional notes…"></textarea>
                    </div>
                </div>
                <div class="tx-col">
                    <h6>Product</h6>
                    <div class="form-group">
                        <label>Product</label>
                        <select name="ItemName">
                            <option value="" disabled selected>Select product…</option>
                            <option>Gold Ring</option>
                            <option>Gold Chain</option>
                            <option>Diamond Necklace</option>
                            <option>Gold Bangle</option>
                            <option>Silver Earrings</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Quantity</label>
                        <input type="number" name="Quantity" placeholder="e.g. 10" min="1" />
                    </div>
                    <div class="form-group">
                        <label>Selling Price (₹)</label>
                        <input type="number" name="UnitPrice" placeholder="e.g. 8000" min="0" />
                    </div>
                    <div class="form-group">
                        <label>Transaction Date</label>
                        <input type="date" name="TransactionDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                </div>
            </div>
            <div class="form-footer">
                <button type="submit" class="btn-submit">Submit Sale</button>
            </div>
        </form>
    }

    <!-- HISTORY Tab -->
    @if (activeTab == "history")
    {
        <h5 style="font-size:16px;font-weight:700;color:#1a1a2e;margin-bottom:20px;">Transaction History</h5>

        <div style="display:flex;gap:10px;margin-bottom:18px;">
            <input type="text" id="histSearch" placeholder="🔍 Search by name, product…"
                   oninput="filterHist()"
                   style="flex:1;padding:8px 14px;border:1px solid #ddd;border-radius:8px;font-size:13px;background:#f9f9fb;outline:none;" />
        </div>

        <table class="hist-table" id="histTable">
            <thead>
                <tr>
                    <th>Tx ID</th>
                    <th>Type</th>
                    <th>Party</th>
                    <th>Product</th>
                    <th>Qty</th>
                    <th>Amount</th>
                    <th>Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>#TX-1001</td>
                    <td><span class="badge-type-sell">Sell</span></td>
                    <td>Mahesh Patel</td>
                    <td>Gold Ring</td>
                    <td>10</td>
                    <td>₹80,000</td>
                    <td>Feb 24, 2026</td>
                    <td><span class="badge-s-paid">Paid</span></td>
                </tr>
                <tr>
                    <td>#TX-1002</td>
                    <td><span class="badge-type-buy">Buy</span></td>
                    <td>Nikhil Supplier</td>
                    <td>Raw Gold</td>
                    <td>500g</td>
                    <td>₹22,500</td>
                    <td>Feb 23, 2026</td>
                    <td><span class="badge-s-pending">Pending</span></td>
                </tr>
                <tr>
                    <td>#TX-1003</td>
                    <td><span class="badge-type-sell">Sell</span></td>
                    <td>Ramesh Jewellers</td>
                    <td>Gold Chain</td>
                    <td>5</td>
                    <td>₹35,000</td>
                    <td>Feb 22, 2026</td>
                    <td><span class="badge-s-paid">Paid</span></td>
                </tr>
                <tr>
                    <td>#TX-1004</td>
                    <td><span class="badge-type-buy">Buy</span></td>
                    <td>Rajan Chemicals</td>
                    <td>Plating Chemicals</td>
                    <td>10 kg</td>
                    <td>₹10,000</td>
                    <td>Feb 21, 2026</td>
                    <td><span class="badge-s-pending">Pending</span></td>
                </tr>
                <tr>
                    <td>#TX-1005</td>
                    <td><span class="badge-type-sell">Sell</span></td>
                    <td>Suresh Traders</td>
                    <td>Gold Bangle</td>
                    <td>20</td>
                    <td>₹28,000</td>
                    <td>Feb 20, 2026</td>
                    <td><span class="badge-s-cancelled">Cancelled</span></td>
                </tr>
                <tr>
                    <td>#TX-1006</td>
                    <td><span class="badge-type-buy">Buy</span></td>
                    <td>Praveen Metals</td>
                    <td>Silver Wire</td>
                    <td>2 kg</td>
                    <td>₹8,000</td>
                    <td>Feb 19, 2026</td>
                    <td><span class="badge-s-paid">Paid</span></td>
                </tr>
            </tbody>
        </table>
    }

</div>

<script>
    function filterHist() {
        const q = document.getElementById('histSearch').value.toLowerCase();
        document.querySelectorAll('#histTable tbody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }
</script>
