@{
    ViewData["Title"] = "Transactions";
    var activeTab = ViewBag.Tab ?? "buy";
}

<style>
    /* ── Tab bar ──────────────────────────────────── */
    .tab-bar {
        display: flex;
        gap: 0;
        border-bottom: 2px solid #e4e9f0;
        margin-bottom: 28px;
    }
    .tab-btn {
        padding: 11px 28px;
        font-size: 14px;
        font-weight: 600;
        color: #888;
        background: none;
        border: none;
        border-bottom: 3px solid transparent;
        margin-bottom: -2px;
        cursor: pointer;
        transition: color .2s, border-color .2s;
        text-decoration: none;
    }
    .tab-btn:hover  { color: #2b8bbd; }
    .tab-btn.active { color: #2b8bbd; border-bottom-color: #2b8bbd; }

    /* ── Form header ──────────────────────────────── */
    .form-title {
        font-size: 17px;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 22px;
    }

    /* ── 3-column grid layout ─────────────────────── */
    .tx-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 18px 24px;
        margin-bottom: 20px;
    }
    @@media (max-width: 800px) { .tx-grid { grid-template-columns: 1fr 1fr; } }
    @@media (max-width: 560px) { .tx-grid { grid-template-columns: 1fr; } }

    .fg { display: flex; flex-direction: column; }
    .fg label {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #999;
        margin-bottom: 5px;
    }
    .fg input,
    .fg select {
        padding: 9px 13px;
        border: 1.5px solid #dde1e7;
        border-radius: 8px;
        font-size: 13px;
        font-family: 'Inter', sans-serif;
        background: #f8f9fb;
        color: #333;
        outline: none;
        transition: border-color .2s, box-shadow .2s;
    }
    .fg input:focus,
    .fg select:focus {
        border-color: #2b8bbd;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(43,139,189,.08);
    }
    .fg input[readonly] {
        background: #eef5fa;
        color: #2b8bbd;
        font-weight: 600;
    }
    .fg input.total-field[readonly] {
        background: #eef5fa;
        color: #333;
        font-weight: 600;
    }

    /* ── Submit row ───────────────────────────────── */
    .form-footer {
        display: flex;
        justify-content: flex-end;
        margin-top: 6px;
    }
    .btn-submit {
        background: linear-gradient(135deg, #2b8bbd, #1a6d99);
        color: #fff;
        border: none;
        padding: 11px 38px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 700;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
        box-shadow: 0 3px 12px rgba(43,139,189,.25);
        transition: all .2s;
    }
    .btn-submit:hover {
        background: linear-gradient(135deg, #23729b, #155a80);
        box-shadow: 0 5px 18px rgba(43,139,189,.35);
        transform: translateY(-1px);
    }

    /* ── History search ───────────────────────────── */
    .hist-search {
        width: 100%;
        padding: 9px 14px;
        border: 1.5px solid #e0e6ed;
        border-radius: 8px;
        font-size: 13px;
        font-family: 'Inter', sans-serif;
        background: #f8f9fb;
        outline: none;
        margin-bottom: 18px;
        transition: border-color .2s;
    }
    .hist-search:focus { border-color: #2b8bbd; background: #fff; }

    /* ── History table ────────────────────────────── */
    .hist-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .hist-table thead th {
        background: #f4f7fb;
        padding: 11px 14px;
        text-align: left;
        font-weight: 700;
        color: #666;
        border-bottom: 2px solid #e4e9f0;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: .4px;
    }
    .hist-table tbody td {
        padding: 12px 14px;
        border-bottom: 1px solid #f2f4f7;
        color: #333;
        vertical-align: middle;
    }
    .hist-table tbody tr:hover { background: #f7fafd; }
    .hist-table tbody tr:last-child td { border-bottom: none; }

    .prod-sub { font-size: 11px; color: #2b8bbd; font-weight: 600; margin-top: 2px; }

    /* ── Type + status badges ─────────────────────── */
    .bdg {
        display: inline-block;
        padding: 3px 11px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
    }
    .bdg-buy      { background: #e8f4fd; color: #2980b9; }
    .bdg-sell     { background: #eafaf1; color: #1e8449; }
    .bdg-received { background: #d1f5e0; color: #155724; }
    .bdg-pending  { background: #fff8e1; color: #856404; }
    .bdg-cancelled{ background: #fdecea; color: #842029; }

    /* ── Edit button ──────────────────────────────── */
    .btn-edit-sm {
        padding: 4px 14px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        background: #f4f6fb;
        color: #555;
        border: 1.5px solid #e0e6ed;
        cursor: pointer;
        transition: background .15s;
    }
    .btn-edit-sm:hover { background: #eaecf2; }

    /* ── Edit Modal ───────────────────────────────── */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 200;
        align-items: center;
        justify-content: center;
    }
    .modal-overlay.open { display: flex; }

    .modal-box {
        background: #fff;
        border-radius: 16px;
        padding: 32px 36px;
        width: 100%;
        max-width: 500px;
        box-shadow: 0 12px 48px rgba(0,0,0,.18);
        animation: slideUp .2s ease;
    }
    @@keyframes slideUp {
        from { transform: translateY(20px); opacity: 0; }
        to   { transform: translateY(0);    opacity: 1; }
    }

    .modal-title {
        font-size: 17px;
        font-weight: 800;
        color: #1a1a2e;
        margin-bottom: 24px;
    }

    .mfg { margin-bottom: 16px; }
    .mfg label {
        display: block;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #999;
        margin-bottom: 5px;
    }
    .mfg input,
    .mfg select {
        width: 100%;
        padding: 10px 14px;
        border: 1.5px solid #dde1e7;
        border-radius: 8px;
        font-size: 13px;
        font-family: 'Inter', sans-serif;
        background: #f8f9fb;
        color: #333;
        outline: none;
        box-sizing: border-box;
        transition: border-color .2s;
    }
    .mfg input:focus,
    .mfg select:focus { border-color: #2b8bbd; background: #fff; }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 24px;
    }
    .btn-cancel {
        padding: 9px 24px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        background: #fff;
        color: #555;
        border: 1.5px solid #dde1e7;
        cursor: pointer;
        transition: background .15s;
        font-family: 'Inter', sans-serif;
    }
    .btn-cancel:hover { background: #f4f6fb; }
    .btn-update {
        padding: 9px 28px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 700;
        background: linear-gradient(135deg, #2b8bbd, #1a6d99);
        color: #fff;
        border: none;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        box-shadow: 0 3px 10px rgba(43,139,189,.25);
        transition: all .2s;
    }
    .btn-update:hover { background: linear-gradient(135deg, #23729b, #155a80); transform: translateY(-1px); }
</style>

<div class="card-box">

    <!-- Tab bar -->
    <div class="tab-bar">
        <a href="/Transaction?tab=buy"     class="tab-btn @(activeTab=="buy"     ? "active" : "")">Buy</a>
        <a href="/Transaction?tab=sell"    class="tab-btn @(activeTab=="sell"    ? "active" : "")">Sell</a>
        <a href="/Transaction?tab=history" class="tab-btn @(activeTab=="history" ? "active" : "")">History</a>
    </div>

    <!-- ══ BUY Tab ══════════════════════════════════ -->
    @if (activeTab == "buy")
    {
        <div class="form-title">New Purchase (Buy)</div>
        <form method="post" action="/Transaction/Create" id="buyForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="TransactionType" value="Buy" />

            <div class="tx-grid">
                <!-- Row 1 -->
                <div class="fg">
                    <label>Transaction ID (Auto)</label>
                    <input type="text" value="RI_@(3006)" readonly />
                </div>
                <div class="fg">
                    <label>Product ID</label>
                    <input type="text" id="buyProductId" name="ProductId" placeholder="RI_100x" />
                </div>
                <div class="fg">
                    <label>Quantity</label>
                    <input type="number" name="Quantity" id="buyQty" min="1" oninput="calcBuyTotal()" />
                </div>

                <!-- Row 2 -->
                <div class="fg">
                    <label>From (Supplier Name)</label>
                    <input type="text" name="CustomerName" placeholder="" />
                </div>
                <div class="fg">
                    <label>Product Name</label>
                    <input type="text" id="buyProductName" name="ItemName" placeholder="" />
                </div>
                <div class="fg">
                    <label>Unit Price (₹)</label>
                    <input type="number" name="UnitPrice" id="buyUnitPrice" min="0" oninput="calcBuyTotal()" />
                </div>

                <!-- Row 3 -->
                <div class="fg">
                    <label>Payment Method</label>
                    <select name="PaymentMethod">
                        <option value="Cash">Cash</option>
                        <option value="BankTransfer">Bank Transfer</option>
                        <option value="Online">Online</option>
                        <option value="CreditCard">Credit Card</option>
                    </select>
                </div>
                <div class="fg">
                    <label>Date</label>
                    <input type="date" name="TransactionDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
                <div class="fg">
                    <label>Total Amount (₹)</label>
                    <input type="text" id="buyTotal" name="TotalAmount" class="total-field" readonly value="0" />
                </div>
            </div>

            <div class="form-footer">
                <button type="submit" class="btn-submit">Complete Purchase</button>
            </div>
        </form>
    }

    <!-- ══ SELL Tab ═════════════════════════════════ -->
    @if (activeTab == "sell")
    {
        <div class="form-title">New Sale (Sell)</div>
        <form method="post" action="/Transaction/Create" id="sellForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="TransactionType" value="Sell" />

            <div class="tx-grid">
                <!-- Row 1 -->
                <div class="fg">
                    <label>Transaction ID (Auto)</label>
                    <input type="text" value="RI_@(3006)" readonly />
                </div>
                <div class="fg">
                    <label>Product ID</label>
                    <input type="text" id="sellProductId" name="ProductId" placeholder="RI_100x" />
                </div>
                <div class="fg">
                    <label>Quantity</label>
                    <input type="number" name="Quantity" id="sellQty" min="1" oninput="calcSellTotal()" />
                </div>

                <!-- Row 2 -->
                <div class="fg">
                    <label>To (Customer Name)</label>
                    <input type="text" name="CustomerName" placeholder="" />
                </div>
                <div class="fg">
                    <label>Product Name</label>
                    <input type="text" id="sellProductName" name="ItemName" placeholder="" />
                </div>
                <div class="fg">
                    <label>Selling Price (₹)</label>
                    <input type="number" name="UnitPrice" id="sellUnitPrice" min="0" oninput="calcSellTotal()" />
                </div>

                <!-- Row 3 -->
                <div class="fg">
                    <label>Payment Method</label>
                    <select name="PaymentMethod">
                        <option value="Cash">Cash</option>
                        <option value="BankTransfer">Bank Transfer</option>
                        <option value="Online">Online</option>
                        <option value="DebitCard">Debit Card</option>
                    </select>
                </div>
                <div class="fg">
                    <label>Date</label>
                    <input type="date" name="TransactionDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
                <div class="fg">
                    <label>Total Amount (₹)</label>
                    <input type="text" id="sellTotal" name="TotalAmount" class="total-field" readonly value="0" />
                </div>
            </div>

            <div class="form-footer">
                <button type="submit" class="btn-submit">Complete Sale</button>
            </div>
        </form>
    }

    <!-- ══ HISTORY Tab ═══════════════════════════════ -->
    @if (activeTab == "history")
    {
        <div class="form-title">Transaction Records</div>

        <input type="text" id="histSearch" class="hist-search"
               placeholder="Search history…" oninput="filterHist()" />

        <table class="hist-table" id="histTable">
            <thead>
                <tr>
                    <th>Tx ID</th>
                    <th>Type</th>
                    <th>Party</th>
                    <th>Product (ID)</th>
                    <th>Qty</th>
                    <th>Total Amount</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>RI 3001</td>
                    <td><span class="bdg bdg-sell">Sell</span></td>
                    <td>Mahesh Patel</td>
                    <td>
                        Gold Ring
                        <div class="prod-sub">RI_1001</div>
                    </td>
                    <td>10</td>
                    <td>₹80,000</td>
                    <td><span class="bdg bdg-received">Received</span></td>
                    <td>
                        <button class="btn-edit-sm"
                                onclick="openEdit('RI_3001','Mahesh Patel','RI_1001','Gold Ring',10,80000,'Received')">
                            Edit
                        </button>
                    </td>
                </tr>
                <tr>
                    <td>RI 3002</td>
                    <td><span class="bdg bdg-buy">Buy</span></td>
                    <td>Nikhil Supplier</td>
                    <td>
                        Raw Gold
                        <div class="prod-sub">RI_1001</div>
                    </td>
                    <td>5</td>
                    <td>₹22,500</td>
                    <td><span class="bdg bdg-pending">Pending</span></td>
                    <td>
                        <button class="btn-edit-sm"
                                onclick="openEdit('RI_3002','Nikhil Supplier','RI_1001','Raw Gold',5,22500,'Pending')">
                            Edit
                        </button>
                    </td>
                </tr>
                <tr>
                    <td>RI 3003</td>
                    <td><span class="bdg bdg-sell">Sell</span></td>
                    <td>Ramesh Jewellers</td>
                    <td>
                        Gold Chain
                        <div class="prod-sub">RI_1002</div>
                    </td>
                    <td>5</td>
                    <td>₹35,000</td>
                    <td><span class="bdg bdg-received">Received</span></td>
                    <td>
                        <button class="btn-edit-sm"
                                onclick="openEdit('RI_3003','Ramesh Jewellers','RI_1002','Gold Chain',5,35000,'Received')">
                            Edit
                        </button>
                    </td>
                </tr>
                <tr>
                    <td>RI 3004</td>
                    <td><span class="bdg bdg-buy">Buy</span></td>
                    <td>Rajan Chemicals</td>
                    <td>
                        Plating Chemicals
                        <div class="prod-sub">RI_1004</div>
                    </td>
                    <td>10</td>
                    <td>₹10,000</td>
                    <td><span class="bdg bdg-pending">Pending</span></td>
                    <td>
                        <button class="btn-edit-sm"
                                onclick="openEdit('RI_3004','Rajan Chemicals','RI_1004','Plating Chemicals',10,10000,'Pending')">
                            Edit
                        </button>
                    </td>
                </tr>
                <tr>
                    <td>RI 3005</td>
                    <td><span class="bdg bdg-sell">Sell</span></td>
                    <td>Suresh Traders</td>
                    <td>
                        Gold Bangle
                        <div class="prod-sub">RI_1004</div>
                    </td>
                    <td>20</td>
                    <td>₹28,000</td>
                    <td><span class="bdg bdg-cancelled">Cancelled</span></td>
                    <td>
                        <button class="btn-edit-sm"
                                onclick="openEdit('RI_3005','Suresh Traders','RI_1004','Gold Bangle',20,28000,'Cancelled')">
                            Edit
                        </button>
                    </td>
                </tr>
            </tbody>
        </table>
    }

</div>

<!-- ══ Edit Modal ════════════════════════════════════ -->
<div class="modal-overlay" id="editModal">
    <div class="modal-box">
        <div class="modal-title" id="modalTitle">Edit Record: RI_3001</div>
        <div class="mfg">
            <label>Party Name</label>
            <input type="text" id="mParty" />
        </div>
        <div class="mfg">
            <label>Product ID</label>
            <input type="text" id="mProductId" />
        </div>
        <div class="mfg">
            <label>Product</label>
            <input type="text" id="mProduct" />
        </div>
        <div class="mfg">
            <label>Quantity</label>
            <input type="number" id="mQty" />
        </div>
        <div class="mfg">
            <label>Total Amount (₹)</label>
            <input type="number" id="mTotal" />
        </div>
        <div class="mfg">
            <label>Status</label>
            <select id="mStatus">
                <option value="Received">Received</option>
                <option value="Pending">Pending</option>
                <option value="Cancelled">Cancelled</option>
            </select>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeEdit()">Cancel</button>
            <button class="btn-update" onclick="saveEdit()">Update</button>
        </div>
    </div>
</div>

<script>
    /* ── History search ──────────────────────────── */
    function filterHist() {
        const q = document.getElementById('histSearch').value.toLowerCase();
        document.querySelectorAll('#histTable tbody tr').forEach(r => {
            r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }

    /* ── Buy total auto-calc ─────────────────────── */
    function calcBuyTotal() {
        const qty   = parseFloat(document.getElementById('buyQty')?.value)       || 0;
        const price = parseFloat(document.getElementById('buyUnitPrice')?.value)  || 0;
        const el    = document.getElementById('buyTotal');
        if (el) el.value = (qty * price).toLocaleString('en-IN');
    }

    /* ── Sell total auto-calc ────────────────────── */
    function calcSellTotal() {
        const qty   = parseFloat(document.getElementById('sellQty')?.value)       || 0;
        const price = parseFloat(document.getElementById('sellUnitPrice')?.value)  || 0;
        const el    = document.getElementById('sellTotal');
        if (el) el.value = (qty * price).toLocaleString('en-IN');
    }

    /* ── Edit modal ──────────────────────────────── */
    function openEdit(txId, party, productId, product, qty, total, status) {
        document.getElementById('modalTitle').textContent  = 'Edit Record: ' + txId;
        document.getElementById('mParty').value     = party;
        document.getElementById('mProductId').value = productId;
        document.getElementById('mProduct').value   = product;
        document.getElementById('mQty').value       = qty;
        document.getElementById('mTotal').value     = total;
        document.getElementById('mStatus').value    = status;
        document.getElementById('editModal').classList.add('open');
    }

    function closeEdit() {
        document.getElementById('editModal').classList.remove('open');
    }

    function saveEdit() {
        // TODO: wire up to a real PATCH/POST endpoint
        alert('Record updated (UI demo).');
        closeEdit();
    }

    // Close modal on overlay click
    document.getElementById('editModal').addEventListener('click', function(e) {
        if (e.target === this) closeEdit();
    });
</script>
