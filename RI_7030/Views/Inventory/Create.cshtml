@{
    ViewData["Title"] = "Add Product";
}

<style>
    .form-card { max-width: 560px; margin: 0 auto; background: #fff; border-radius: 14px; padding: 32px 36px; box-shadow: 0 4px 18px rgba(0,0,0,0.09); }
    .form-card h5 { font-size: 20px; font-weight: 700; color: #1a1a2e; margin-bottom: 24px; text-align: center; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 11px; font-weight: 700; color: #666; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 6px; }
    .form-group input, .form-group select {
        width: 100%; padding: 10px 14px; border: 1px solid #dde1e7; border-radius: 8px;
        font-size: 13px; background: #f9f9fb; color: #333; outline: none; box-sizing: border-box; transition: border-color .2s;
    }
    .form-group input:focus, .form-group select:focus { border-color: #4a8dac; background: #fff; }
    .stage-checks { display: grid; grid-template-columns: repeat(2,1fr); gap: 10px; margin-top: 4px; }
    .stage-check { display: flex; align-items: center; gap: 8px; padding: 10px 12px; border-radius: 8px; background: #f9f9fb; border: 1px solid #e0e6ed; font-size: 13px; font-weight: 600; color: #444; cursor: pointer; }
    .stage-check input[type=checkbox] { width: 16px; height: 16px; accent-color: #27ae60; }
    .form-actions { display: flex; gap: 10px; justify-content: center; margin-top: 24px; }
    .btn-submit { background: #4a8dac; color: #fff; border: none; padding: 11px 36px; border-radius: 8px; font-size: 14px; font-weight: 700; cursor: pointer; transition: background .2s; }
    .btn-submit:hover { background: #3a7a98; }
    .btn-cancel { background: #f0f0f0; color: #555; border: none; padding: 11px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-block; }
    .btn-cancel:hover { background: #e0e0e0; }
</style>

<div class="form-card">
    <h5>➕ Add Product</h5>

    <form method="post" action="/Inventory/Create">
        @Html.AntiForgeryToken()

        <div class="form-row">
            <div class="form-group">
                <label>Product Name</label>
                <input type="text" name="ProductName" placeholder="e.g. Gold Ring" required />
            </div>
            <div class="form-group">
                <label>Stock Quantity</label>
                <input type="number" name="StockQuantity" placeholder="e.g. 100" min="0" required />
            </div>
        </div>

        <div class="form-group">
            <label>Product Image URL (optional)</label>
            <input type="text" name="ImagePath" placeholder="e.g. /images/ring.jpg" />
        </div>

        <div class="form-group">
            <label>Production Stages Completed</label>
            <div class="stage-checks">
                <label class="stage-check">
                    <input type="checkbox" name="IsCastingDone" value="true" />
                    🔨 Stage 1 – Casting
                </label>
                <label class="stage-check">
                    <input type="checkbox" name="IsFinishingTouchDone" value="true" />
                    ✨ Stage 2 – Finishing Touch
                </label>
                <label class="stage-check">
                    <input type="checkbox" name="IsGoldPlatingDone" value="true" />
                    🥇 Stage 3 – Gold Plating
                </label>
                <label class="stage-check">
                    <input type="checkbox" name="IsPackagingDone" value="true" />
                    📦 Stage 4 – Packaging
                </label>
            </div>
        </div>

        <div class="form-actions">
            <a href="/Inventory" class="btn-cancel">Cancel</a>
            <button type="submit" class="btn-submit">Add Product</button>
        </div>
    </form>
</div>
