@model List<RI_7030.Models.Product>
@{
    ViewData["Title"] = "Inventory";
    var isAdmin = Context.Session.GetString("Role") == "Admin";
    var search  = ViewBag.Search as string ?? "";
    var nextId  = ViewBag.NextId as string ?? "";
    var T  = ViewBag.T as Dictionary<string, string> ?? new();
    string Tr(string k) => T.TryGetValue(k, out var v) ? v : k;
}

<style>
    .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
    .page-header h5 { margin:0; font-size:18px; font-weight:700; color:#1a1a2e; }
    .btn-primary-sm { background:linear-gradient(135deg,#2b8bbd,#1a6d99); color:#fff; border:none; padding:9px 20px; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:6px; box-shadow:0 3px 10px rgba(43,139,189,.25); }
    .search-bar { display:flex; gap:10px; margin-bottom:18px; }
    .search-bar input { flex:1; padding:8px 14px; border:1.5px solid #e0e6ed; border-radius:8px; font-size:13px; background:#f9f9fb; outline:none; }
    .inv-table { width:100%; border-collapse:collapse; font-size:13px; }
    .inv-table thead th { background:#f0f4f8; padding:10px 14px; text-align:left; font-weight:700; color:#555; border-bottom:2px solid #e0e6ed; }
    .inv-table tbody td { padding:11px 14px; border-bottom:1px solid #f0f0f0; color:#333; vertical-align:middle; }
    .inv-table tbody tr:hover { background:#f7fafc; }
    .stage-track { display:flex; gap:4px; align-items:center; }
    .stage-dot { width:20px; height:20px; border-radius:50%; font-size:9px; font-weight:700; display:flex; align-items:center; justify-content:center; }
    .stage-done { background:#27ae60; color:#fff; } .stage-pending { background:#ddd; color:#999; }
    .stock-low { color:#e74c3c; font-weight:700; } .stock-ok { color:#27ae60; font-weight:700; }
    .action-btn { padding:4px 12px; border-radius:6px; font-size:11px; font-weight:600; border:none; cursor:pointer; text-decoration:none; display:inline-block; }
    .btn-edit   { background:#eaf4fb; color:#2980b9; } .btn-delete { background:#fdedec; color:#c0392b; margin-left:4px; }
    .empty-state { text-align:center; color:#bbb; padding:40px; }
    .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:200; align-items:center; justify-content:center; }
    .modal-overlay.open { display:flex; }
    .modal-box { background:#fff; border-radius:12px; padding:28px 36px; width:100%; box-shadow:0 12px 40px rgba(0,0,0,.15); animation:slideUp .2s ease; }
    .modal-box.md-large { max-width:520px; }
    @@keyframes slideUp { from { transform:translateY(20px); opacity:0; } to { transform:translateY(0); opacity:1; } }
    .modal-title { font-size:18px; font-weight:700; color:#1a1a2e; margin-bottom:20px; display:flex; align-items:center; justify-content:space-between; }
    .modal-close { background:none; border:none; font-size:20px; color:#999; cursor:pointer; }
    .modal-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px; }
    .mfg { display:flex; flex-direction:column; }
    .mfg label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:#777; margin-bottom:5px; }
    .mfg input, .mfg select { width:100%; padding:9px 13px; border:1.5px solid #dde1e7; border-radius:8px; font-size:13px; background:#fff; color:#333; outline:none; box-sizing:border-box; }
    .mfg input:focus { border-color:#2b8bbd; } .mfg input[readonly] { background:#eef5fa; color:#2b8bbd; font-weight:600; }
    .stages-row { display:flex; gap:14px; flex-wrap:wrap; font-size:12px; font-weight:600; color:#444; }
    .stages-row label { display:flex; align-items:center; gap:5px; }
    .modal-footer { display:flex; justify-content:flex-end; gap:12px; margin-top:20px; }
    .btn-cancel { padding:9px 24px; border-radius:8px; font-size:13px; font-weight:600; background:#fff; color:#555; border:1.5px solid #dde1e7; cursor:pointer; }
    .btn-action { padding:9px 24px; border-radius:8px; font-size:13px; font-weight:600; background:#39a0c8; color:#fff; border:none; cursor:pointer; }
</style>

<div class="card-box">
    <div class="page-header">
        <h5>@Tr("inventory_title")</h5>
        @if (isAdmin)
        {
            <button class="btn-primary-sm" onclick="openModal('addProdModal')">@Tr("add_product")</button>
        }
    </div>

    <form method="get" class="search-bar">
        <input name="search" type="text" value="@search" placeholder="@Tr("search_inventory")" />
        <button type="submit" class="btn-primary-sm">@Tr("search")</button>
    </form>

    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">@Tr("no_products") @(isAdmin ? Tr("add_first") : "")</div>
    }
    else
    {
        <table class="inv-table" id="invTable">
            <thead>
                <tr><th>@Tr("product_id")</th><th>@Tr("product_name")</th><th>@Tr("stock")</th><th>@Tr("unit_cost")</th><th>@Tr("prod_stages")</th><th>@Tr("progress")</th><th>@Tr("actions")</th></tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><strong>@p.ProductId</strong></td>
                        <td>@p.Name</td>
                        <td class="@(p.LowStock ? "stock-low" : "stock-ok")">@p.Stock @Tr("pcs") @(p.LowStock ? "⚠" : "")</td>
                        <td>₹@p.UnitCost.ToString("N0")</td>
                        <td>
                            <div class="stage-track">
                                <div class="stage-dot @(p.Stage_Casting ? "stage-done" : "stage-pending")" title="@Tr("casting")">C</div>
                                <div class="stage-dot @(p.Stage_Finishing ? "stage-done" : "stage-pending")" title="@Tr("finishing")">F</div>
                                <div class="stage-dot @(p.Stage_GoldPlating ? "stage-done" : "stage-pending")" title="@Tr("gold_plating")">G</div>
                                <div class="stage-dot @(p.Stage_Packaging ? "stage-done" : "stage-pending")" title="@Tr("packaging")">P</div>
                            </div>
                        </td>
                        <td><span style="font-size:12px;font-weight:700;color:@(p.IsComplete ? "#27ae60" : "#f39c12")">@p.CompletionPercentage%</span></td>
                        <td>
                            <button class="action-btn btn-edit" onclick="openEditModal('@p.ProductId','@p.Name.Replace("'", "\\'")','@p.Stock','@p.UnitCost','@p.Stage_Casting.ToString().ToLower()','@p.Stage_Finishing.ToString().ToLower()','@p.Stage_GoldPlating.ToString().ToLower()','@p.Stage_Packaging.ToString().ToLower()')">@Tr("edit")</button>
                            @if (isAdmin)
                            {
                                <form method="post" action="/Inventory/Delete/@p.ProductId" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="action-btn btn-delete" onclick="return confirm('Delete product @p.ProductId?')">@Tr("del")</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div style="margin-top:14px;font-size:11px;color:#aaa;display:flex;gap:14px;align-items:center;">
        <span><span style="display:inline-block;width:10px;height:10px;background:#27ae60;border-radius:50%;margin-right:4px;"></span>@Tr("done")</span>
        <span><span style="display:inline-block;width:10px;height:10px;background:#ddd;border-radius:50%;margin-right:4px;"></span>@Tr("s_pending")</span>
        <span>C=@Tr("casting") | F=@Tr("finishing") | G=@Tr("gold_plating") | P=@Tr("packaging")</span>
    </div>
</div>

<!-- Add Product Modal -->
@if (isAdmin)
{
    <div class="modal-overlay" id="addProdModal">
        <div class="modal-box md-large">
            <div class="modal-title">
                <span>@Tr("add_new_product")</span>
                <button class="modal-close" onclick="closeModal('addProdModal')">×</button>
            </div>
            <form method="post" action="/Inventory/Create">
                @Html.AntiForgeryToken()
                <div class="modal-grid">
                    <div class="mfg"><label>@Tr("product_id") (Auto)</label><input type="text" value="@nextId" readonly /></div>
                    <div class="mfg"><label>@Tr("product_name")</label><input name="name" type="text" required /></div>
                    <div class="mfg"><label>@Tr("stock_qty")</label><input name="stock" type="number" min="0" required /></div>
                    <div class="mfg"><label>@Tr("unit_cost") (₹)</label><input name="unitCost" type="number" min="0" step="0.01" /></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-cancel" onclick="closeModal('addProdModal')">@Tr("cancel")</button>
                    <button type="submit" class="btn-action">@Tr("save_product")</button>
                </div>
            </form>
        </div>
    </div>
}

<!-- Edit Product Modal -->
<div class="modal-overlay" id="editProdModal">
    <div class="modal-box md-large">
        <div class="modal-title">
            <span id="epTitle">@Tr("edit_product")</span>
            <button class="modal-close" onclick="closeModal('editProdModal')">×</button>
        </div>
        <form method="post" id="editProdForm">
            @Html.AntiForgeryToken()
            <div class="modal-grid">
                <div class="mfg"><label>@Tr("product_name")</label><input name="name" id="epName" type="text" required /></div>
                <div class="mfg"><label>@Tr("stock_qty")</label><input name="stock" id="epStock" type="number" min="0" required /></div>
                <div class="mfg"><label>@Tr("unit_cost") (₹)</label><input name="unitCost" id="epCost" type="number" min="0" step="0.01" /></div>
            </div>
            <div class="mfg" style="margin-bottom:14px;">
                <label>@Tr("stages_check")</label>
                <div class="stages-row" style="margin-top:8px;">
                    <label><input type="checkbox" name="stageCasting"    id="epC" /> @Tr("casting")</label>
                    <label><input type="checkbox" name="stageFinishing"  id="epF" /> @Tr("finishing")</label>
                    <label><input type="checkbox" name="stageGoldPlating" id="epG" /> @Tr("gold_plating")</label>
                    <label><input type="checkbox" name="stagePackaging"  id="epP" /> @Tr("packaging")</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" onclick="closeModal('editProdModal')">@Tr("cancel")</button>
                <button type="submit" class="btn-action">@Tr("update_product")</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openModal(id) { document.getElementById(id).classList.add('open'); }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }
    document.querySelectorAll('.modal-overlay').forEach(el => {
        el.addEventListener('click', e => { if (e.target === el) closeModal(el.id); });
    });
    function openEditModal(id, name, stock, cost, c, f, g, p) {
        document.getElementById('epTitle').textContent = '@Tr("edit_product"): ' + id;
        document.getElementById('editProdForm').action = '/Inventory/Edit/' + id;
        document.getElementById('epName').value = name;
        document.getElementById('epStock').value = stock;
        document.getElementById('epCost').value = cost;
        document.getElementById('epC').checked = c === 'true';
        document.getElementById('epF').checked = f === 'true';
        document.getElementById('epG').checked = g === 'true';
        document.getElementById('epP').checked = p === 'true';
        openModal('editProdModal');
    }
</script>
