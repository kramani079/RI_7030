        </tbody>
    </table>

    <div style="margin-top:14px;font-size:11px;color:#aaa;display:flex;gap:14px;align-items:center;">
        <span><span style="display:inline-block;width:12px;height:12px;background:#27ae60;border-radius:50%;margin-right:4px;"></span>Done</span>
        <span><span style="display:inline-block;width:12px;height:12px;background:#ddd;border-radius:50%;margin-right:4px;"></span>Pending</span>
        <span>C = Casting &nbsp;|&nbsp; F = Finishing Touch &nbsp;|&nbsp; G = Gold Plating &nbsp;|&nbsp; P = Packaging</span>
    </div>
</div>

<button class="floating-add" title="Add Product" onclick="openAddModal()">＋</button>

<!-- ── Modals Styles ─────────────────────────────── -->
<style>
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 200; align-items: center; justify-content: center; }
    .modal-overlay.open { display: flex; }
    .modal-box { background: #fff; border-radius: 12px; padding: 28px 36px; width: 100%; box-shadow: 0 12px 40px rgba(0,0,0,.15); position: relative; animation: slideUp .2s ease; }
    .modal-box.md-large { max-width: 600px; }
    .modal-box.md-view { max-width: 400px; }
    @@keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    .modal-title { font-size: 18px; font-weight: 700; color: #1a1a2e; margin-bottom: 24px; display: flex; align-items: center; justify-content: space-between; }
    .modal-close { background: none; border: none; font-size: 20px; color: #999; cursor: pointer; }
    .modal-close:hover { color: #333; }

    .modal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
    .modal-grid.col-3 { grid-template-columns: 1fr 1fr 1fr; }

    .mfg { display: flex; flex-direction: column; }
    .mfg label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #777; margin-bottom: 6px; }
    .mfg input, .mfg select, .mfg textarea { width: 100%; padding: 10px 14px; border: 1.5px solid #dde1e7; border-radius: 8px; font-size: 13px; font-family: 'Inter', sans-serif; background: #fff; color: #333; outline: none; transition: border-color .2s; }
    .mfg textarea { resize: vertical; min-height: 60px; }
    .mfg input:focus, .mfg select:focus, .mfg textarea:focus { border-color: #2b8bbd; box-shadow: 0 0 0 3px rgba(43,139,189,.08); }
    .mfg input[readonly] { background: #eef5fa; color: #2b8bbd; font-weight: 600; border: none; }
    
    .stages-row { display: flex; gap: 14px; align-items: center; margin-top: 4px; }
    .stage-cb { display: flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 600; color: #444; }

    .modal-footer { display: flex; justify-content: flex-end; gap: 12px; margin-top: 24px; }
    .btn-cancel { padding: 9px 24px; border-radius: 8px; font-size: 13px; font-weight: 600; background: #fff; color: #555; border: 1.5px solid #dde1e7; cursor: pointer; transition: background .15s; }
    .btn-cancel:hover { background: #f4f6fb; }
    .btn-action { padding: 9px 24px; border-radius: 8px; font-size: 13px; font-weight: 600; background: #39a0c8; color: #fff; border: none; cursor: pointer; transition: background .2s; }
    .btn-action:hover { background: #2f8aaebb; }

    .det-row { display: flex; align-items: baseline; font-size: 14px; margin-bottom: 8px; line-height: 1.4; }
    .det-lbl { font-weight: 700; color: #1a1a2e; width: 130px; flex-shrink: 0; }
    .det-val { color: #333; font-weight: 500; }
    .btn-view { background: #fdf0ef; color: #c0392b; }
    .btn-view:hover { background: #fce1de; }
</style>

<!-- ── Add Product Modal ───────────────────────── -->
<div class="modal-overlay" id="addProdModal">
    <div class="modal-box md-large">
        <div class="modal-title">
            <span>+ Add New Product</span>
            <button class="modal-close" onclick="closeModal('addProdModal')">×</button>
        </div>
        <div class="modal-grid">
            <div class="mfg"><label>Product ID (Auto)</label><input type="text" value="RI_1007" readonly /></div>
            <div class="mfg"><label>Product Name</label><input type="text" id="apName" /></div>
            <div class="mfg"><label>Assigned To</label>
                <select id="apAssign"><option>Aarav Patel</option><option>Rajesh Kumar</option></select>
            </div>
            <div class="mfg"><label>Price (₹)</label><input type="number" id="apPrice" /></div>
        </div>
        <div class="mfg" style="margin-bottom:14px;"><label>Description</label><textarea id="apDesc"></textarea></div>
        
        <div class="mfg" style="margin-bottom:14px;">
            <label>Production Stages & Process</label>
            <div class="stages-row">
                <label class="stage-cb"><input type="checkbox" checked> Casting</label>
                <label class="stage-cb"><input type="checkbox" checked> Finishing</label>
                <label class="stage-cb"><input type="checkbox" checked> Gold Plating</label>
                <label class="stage-cb"><input type="checkbox" checked> Packaging</label>
            </div>
        </div>

        <div class="modal-grid col-3">
            <div class="mfg"><label>Stock Quantity</label><input type="number" id="apStock" /></div>
            <div class="mfg"><label>Default Status</label>
                <select id="apStatus"><option>In Production</option><option>Pending</option><option>Ready</option></select>
            </div>
            <div class="mfg"><label>Start Date</label><input type="date" id="apStart" /></div>
            <div class="mfg"><label>Time</label><input type="time" id="apTime" /></div>
            <div class="mfg"><label>End Date</label><input type="date" id="apEnd" /></div>
            <div class="mfg"><label>Duration (Hours)</label><input type="number" id="apDur" /></div>
        </div>

        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('addProdModal')">Cancel</button>
            <button class="btn-action" onclick="closeModal('addProdModal')">Save Product</button>
        </div>
    </div>
</div>

<!-- ── Edit Product Modal ───────────────────────── -->
<div class="modal-overlay" id="editProdModal">
    <div class="modal-box md-large">
        <div class="modal-title">
            <span>Edit Product</span>
            <button class="modal-close" onclick="closeModal('editProdModal')">×</button>
        </div>
        <div class="modal-grid">
            <div class="mfg"><label>Product Name</label><input type="text" id="epName" /></div>
            <div class="mfg"><label>Assigned To</label><select id="epAssign"><option>Aarav Patel</option><option>Rajesh Kumar</option></select></div>
            <div class="mfg"><label>Price (₹)</label><input type="number" id="epPrice" /></div>
            <div class="mfg"><label>Stock Quantity</label><input type="number" id="epStock" /></div>
        </div>
        <div class="mfg" style="margin-bottom:14px;"><label>Description</label><textarea id="epDesc"></textarea></div>
        
        <div class="mfg" style="margin-bottom:14px;">
            <label>Production Stages</label>
            <div class="stages-row">
                <label class="stage-cb"><input type="checkbox" checked> Casting</label>
                <label class="stage-cb"><input type="checkbox" checked> Finishing</label>
                <label class="stage-cb"><input type="checkbox" checked> Gold Plating</label>
                <label class="stage-cb"><input type="checkbox" checked> Packaging</label>
            </div>
        </div>

        <div class="modal-grid col-3">
            <div class="mfg"><label>Stock Status</label>
                <select id="epStatus"><option>In Stock</option><option>Low Stock</option><option>Out of Stock</option></select>
            </div>
            <div class="mfg"><label>Start Date</label><input type="date" id="epStart" /></div>
            <div class="mfg"><label>End Date</label><input type="date" id="epEnd" /></div>
        </div>

        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('editProdModal')">Cancel</button>
            <button class="btn-action" onclick="closeModal('editProdModal')">Update Product</button>
        </div>
    </div>
</div>

<!-- ── Product Info Modal ───────────────────────── -->
<div class="modal-overlay" id="infoProdModal">
    <div class="modal-box md-view">
        <div class="modal-title">
            <span>Product Info</span>
            <button class="modal-close" onclick="closeModal('infoProdModal')">×</button>
        </div>
        <div>
            <div class="det-row"><span class="det-lbl">Product ID:</span><span class="det-val" id="ipId">RI_1001</span></div>
            <div class="det-row"><span class="det-lbl">Product Name:</span><span class="det-val" id="ipName">Gold Ring</span></div>
            <div class="det-row"><span class="det-lbl">Production Stage:</span><span class="det-val" id="ipStage">Packaging</span></div>
            <div class="det-row"><span class="det-lbl">Total Stock:</span><span class="det-val" id="ipStock">150 pcs</span></div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('infoProdModal')">Close</button>
        </div>
    </div>
</div>

<script>
    function openModal(id) { document.getElementById(id).classList.add('open'); }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }

    function openAddModal() { openModal('addProdModal'); }

    function openEditModal(id, name, assign, desc, price, stock, start, end) {
        document.getElementById('epName').value = name;
        document.getElementById('epAssign').value = assign;
        document.getElementById('epDesc').value = desc;
        document.getElementById('epPrice').value = price;
        document.getElementById('epStock').value = stock;
        document.getElementById('epStart').value = start;
        document.getElementById('epEnd').value = end;
        openModal('editProdModal');
    }

    function openInfoModal(id, name, stage, stock) {
        document.getElementById('ipId').textContent = id;
        document.getElementById('ipName').textContent = name;
        document.getElementById('ipStage').textContent = stage;
        document.getElementById('ipStock').textContent = stock + ' pcs';
        openModal('infoProdModal');
    }

    document.querySelectorAll('.modal-overlay').forEach(el => {
        el.addEventListener('click', e => { if (e.target === el) closeModal(el.id); });
    });
</script>
