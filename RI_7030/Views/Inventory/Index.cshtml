                    </div>
                </td>
                <td><span class="pct-text pct-0">0% — Not Started</span></td>
                <td>
                    <button class="action-btn btn-view" onclick="openInfoModal('RI_1005', 'Silver Earrings', 'Pending', 8)">Info</button>
                    <button class="action-btn btn-edit" onclick="openEditModal('RI_1005', 'Silver Earrings', 'Aarav Patel', 'Silver', 2500, 8, '2026-02-19', '2026-02-21')">Edit</button>
