@{
    ViewData["Title"] = "Edit Employee";
    var id = ViewContext.RouteData.Values["id"];
}

<style>
    .form-card { max-width: 520px; margin: 0 auto; background: #fff; border-radius: 14px; padding: 32px 36px; box-shadow: 0 4px 18px rgba(0,0,0,0.09); }
    .form-card h5 { font-size: 20px; font-weight: 700; color: #1a1a2e; margin-bottom: 6px; text-align: center; }
    .form-card .sub-id { text-align:center; font-size:12px; color:#aaa; margin-bottom:22px; }
    .form-group { margin-bottom: 18px; }
    .form-group label { display: block; font-size: 11px; font-weight: 700; color: #666; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 6px; }
    .form-group input, .form-group select {
        width: 100%; padding: 10px 14px; border: 1px solid #dde1e7; border-radius: 8px;
        font-size: 13px; background: #f9f9fb; color: #333; outline: none; box-sizing: border-box;
    }
    .form-group input:focus, .form-group select:focus { border-color: #4a8dac; background: #fff; }
    .form-actions { display: flex; gap: 10px; justify-content: center; margin-top: 24px; }
    .btn-submit { background: #4a8dac; color: #fff; border: none; padding: 11px 36px; border-radius: 8px; font-size: 14px; font-weight: 700; cursor: pointer; }
    .btn-submit:hover { background: #3a7a98; }
    .btn-cancel { background: #f0f0f0; color: #555; border: none; padding: 11px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; text-decoration: none; display: inline-block; }
</style>

<div class="form-card">
    <h5>✏ Edit Employee</h5>
    <div class="sub-id">Employee ID: #EMP-00@id</div>

    <form method="post" action="/Employee/Edit/@id">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Employee Name</label>
            <input type="text" name="EmployeeName" placeholder="e.g. Rajesh Kumar" required />
        </div>

        <div class="form-group">
            <label>Email ID</label>
            <input type="email" name="Email" placeholder="e.g. rajesh@ri.com" required />
        </div>

        <div class="form-group">
            <label>Mobile No.</label>
            <input type="tel" name="Phone" placeholder="e.g. +91 98765 43210" />
        </div>

        <div class="form-group">
            <label>Type of Employee</label>
            <select name="EmployeeType" required>
                <option value="1">1 – Casting</option>
                <option value="2">2 – Finishing Touch</option>
                <option value="3">3 – Gold Plating</option>
                <option value="4">4 – Packaging</option>
            </select>
        </div>

        <div class="form-group">
            <label>Salary (₹)</label>
            <input type="number" name="Salary" placeholder="e.g. 22000" min="0" required />
        </div>

        <div class="form-actions">
            <a href="/Employee" class="btn-cancel">Cancel</a>
            <button type="submit" class="btn-submit">Save Changes</button>
        </div>
    </form>
</div>
