@model List<RI_7030.Models.Employee>
@{
    ViewData["Title"] = "Employees";
    var search = ViewBag.Search as string ?? "";
    var nextId = ViewBag.NextId as string ?? "";
    var T  = ViewBag.T as Dictionary<string, string> ?? new();
    string Tr(string k) => T.TryGetValue(k, out var v) ? v : k;
}

<style>
    .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
    .page-header h5 { margin: 0; font-size: 18px; font-weight: 700; color: #1a1a2e; }
    .search-bar { display: flex; gap: 10px; margin-bottom: 18px; }
    .search-bar input { flex: 1; padding: 9px 14px; border: 1.5px solid #e0e6ed; border-radius: 8px; font-size: 13px; background: #f8f9fb; outline: none; }
    .search-bar input:focus { border-color: #2b8bbd; background: #fff; }
    .btn-primary-sm { background: linear-gradient(135deg, #2b8bbd, #1a6d99); color: #fff; border: none; padding: 9px 20px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; box-shadow: 0 3px 10px rgba(43,139,189,.25); }
    .emp-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .emp-table thead th { background: #f4f7fb; padding: 11px 14px; text-align: left; font-weight: 700; color: #666; border-bottom: 2px solid #e4e9f0; text-transform: uppercase; font-size: 11px; letter-spacing: .4px; }
    .emp-table tbody td { padding: 12px 14px; border-bottom: 1px solid #f2f4f7; color: #333; vertical-align: middle; }
    .emp-table tbody tr:hover { background: #f7fafd; }
    .avatar-circle { width: 36px; height: 36px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; color: #fff; }
    .type-badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .type-casting   { background: #e8f4fd; color: #2980b9; }
    .type-finishing { background: #eafaf1; color: #1e8449; }
    .type-plating   { background: #fef9e7; color: #b7950b; }
    .type-packaging { background: #f4ecf7; color: #7d3c98; }
    .type-general   { background: #f0f0f0; color: #555; }
    .badge-new { background: #FF5722; color: #fff; font-size: 9px; padding: 2px 6px; border-radius: 10px; font-weight: 700; margin-left: 6px; }
    .action-btn { padding: 5px 12px; border-radius: 6px; font-size: 11px; font-weight: 600; border: 1.5px solid transparent; cursor: pointer; background: #f4f6fb; color: #555; border-color: #e0e6ed; transition: background .15s; }
    .action-btn:hover { background: #eaecf2; }
    .btn-pay { background: #e8f4fd; color: #2980b9; border-color: #c8e1f1; margin-left: 4px; }
    .btn-del { background: #fdedec; color: #c0392b; border-color: #f5b7b1; margin-left: 4px; }
    .empty-state { text-align: center; color: #bbb; padding: 40px; }
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 200; align-items: center; justify-content: center; }
    .modal-overlay.open { display: flex; }
    .modal-box { background: #fff; border-radius: 12px; padding: 32px 40px; width: 100%; max-width: 440px; box-shadow: 0 12px 40px rgba(0,0,0,.15); animation: slideUp .2s ease; }
    @@keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    .modal-title { font-size: 18px; font-weight: 700; color: #1a1a2e; margin-bottom: 24px; display: flex; align-items: center; justify-content: space-between; }
    .modal-close { background: none; border: none; font-size: 20px; color: #999; cursor: pointer; }
    .mfg { margin-bottom: 16px; }
    .mfg label { display: block; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #777; margin-bottom: 6px; }
    .mfg input, .mfg select { width: 100%; padding: 10px 14px; border: 1.5px solid #dde1e7; border-radius: 8px; font-size: 13px; font-family: 'Inter', sans-serif; background: #fff; color: #333; outline: none; box-sizing: border-box; }
    .mfg input:focus, .mfg select:focus { border-color: #2b8bbd; box-shadow: 0 0 0 3px rgba(43,139,189,.08); }
    .mfg input[readonly] { background: #eef5fa; color: #2b8bbd; font-weight: 600; border-color: #d1e2ef; border-style: dashed; }
    .modal-footer { display: flex; justify-content: flex-end; gap: 12px; margin-top: 28px; }
    .btn-cancel { padding: 9px 24px; border-radius: 8px; font-size: 13px; font-weight: 600; background: #fff; color: #555; border: 1.5px solid #dde1e7; cursor: pointer; }
    .btn-action { padding: 9px 24px; border-radius: 8px; font-size: 13px; font-weight: 600; background: #39a0c8; color: #fff; border: none; cursor: pointer; }
</style>

<div class="card-box">
    <div class="page-header">
        <h5>@Tr("employees_title")</h5>
        <button class="btn-primary-sm" onclick="openModal('newHireModal')">@Tr("new_hire")</button>
    </div>

    <form method="get" class="search-bar">
        <input name="search" type="text" value="@search" placeholder="@Tr("search_emp")" />
        <button type="submit" class="btn-primary-sm">@Tr("search")</button>
    </form>

    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">@Tr("no_employees")</div>
    }
    else
    {
        <table class="emp-table" id="empTable">
            <thead>
                <tr><th>@Tr("id")</th><th>@Tr("employee")</th><th>@Tr("email")</th><th>@Tr("department")</th><th>@Tr("salary")</th><th>@Tr("joined")</th><th>@Tr("actions")</th></tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    var isNew = (DateTime.Now - e.CreatedAt).TotalDays <= 7;
                    var initials = string.Join("", e.FullName.Split(' ').Take(2).Select(w => w[0])).ToUpper();
                    var colors = new[] { "#2b8bbd", "#27ae60", "#f39c12", "#7d3c98", "#e74c3c" };
                    var color = colors[Math.Abs(e.FullName.GetHashCode()) % colors.Length];
                    var deptClass = e.Department switch {
                        "Casting" => "type-casting",
                        "Finishing Touch" => "type-finishing",
                        "Gold Plating" => "type-plating",
                        "Packaging" => "type-packaging",
                        _ => "type-general"
                    };
                    <tr>
                        <td><strong>@e.EmployeeId</strong></td>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px;">
                                <div class="avatar-circle" style="background:@color">@initials</div>
                                <span style="font-weight:600;">@e.FullName @if (isNew) { <span class="badge-new">NEW</span> }</span>
                            </div>
                        </td>
                        <td>@e.Email</td>
                        <td><span class="type-badge @deptClass">@(e.Department ?? "General")</span></td>
                        <td>₹@e.Salary.ToString("N0")</td>
                        <td>@e.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <button class="action-btn" onclick="openEditModal('@e.EmployeeId','@e.FullName.Replace("'", "\\'")','@e.Email','@(e.Department ?? "")','@e.Salary')">@Tr("edit")</button>
                            <button class="action-btn btn-pay" onclick="openPayModal('@e.EmployeeId','@e.FullName.Replace("'", "\\'")','@e.Salary')">@Tr("pay")</button>
                            <form method="post" action="/Employee/Delete/@e.EmployeeId" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="action-btn btn-del" onclick="return confirm('@Tr("delete_confirm_emp")')">@Tr("del")</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- New Hire Modal -->
<div class="modal-overlay" id="newHireModal">
    <div class="modal-box">
        <div class="modal-title">
            <span>@Tr("new_hire")</span>
            <button class="modal-close" onclick="closeModal('newHireModal')">×</button>
        </div>
        <form method="post" action="/Employee/Create">
            @Html.AntiForgeryToken()
            <div class="mfg"><label>@Tr("emp_id_auto")</label><input type="text" value="@nextId" readonly /></div>
            <div class="mfg"><label>@Tr("full_name")</label><input name="fullName" type="text" required /></div>
            <div class="mfg"><label>@Tr("email_address")</label><input name="email" type="email" required /></div>
            <div class="mfg"><label>@Tr("department")</label>
                <select name="department">
                    <option value="Casting">@Tr("casting")</option>
                    <option value="Finishing Touch">@Tr("finishing_touch")</option>
                    <option value="Gold Plating">@Tr("gold_plating")</option>
                    <option value="Packaging">@Tr("packaging")</option>
                </select>
            </div>
            <div class="mfg"><label>@Tr("salary") (₹)</label><input name="salary" type="number" min="0" step="500" /></div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" onclick="closeModal('newHireModal')">@Tr("cancel")</button>
                <button type="submit" class="btn-action">@Tr("create_record")</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Employee Modal -->
<div class="modal-overlay" id="updateEmpModal">
    <div class="modal-box">
        <div class="modal-title">
            <span id="ueTitle">@Tr("update_employee")</span>
            <button class="modal-close" onclick="closeModal('updateEmpModal')">×</button>
        </div>
        <form method="post" id="editEmpForm">
            @Html.AntiForgeryToken()
            <div class="mfg"><label>@Tr("full_name")</label><input name="fullName" id="ueName" type="text" required /></div>
            <div class="mfg"><label>@Tr("email")</label><input name="email" id="ueEmail" type="email" required /></div>
            <div class="mfg"><label>@Tr("department")</label>
                <select name="department" id="ueDept">
                    <option value="Casting">@Tr("casting")</option>
                    <option value="Finishing Touch">@Tr("finishing_touch")</option>
                    <option value="Gold Plating">@Tr("gold_plating")</option>
                    <option value="Packaging">@Tr("packaging")</option>
                </select>
            </div>
            <div class="mfg"><label>@Tr("salary") (₹)</label><input name="salary" id="ueSalary" type="number" min="0" step="500" /></div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" onclick="closeModal('updateEmpModal')">@Tr("cancel")</button>
                <button type="submit" class="btn-action">@Tr("update_employee")</button>
            </div>
        </form>
    </div>
</div>

<!-- Pay Salary Modal -->
<div class="modal-overlay" id="payModal">
    <div class="modal-box">
        <div class="modal-title">
            <span id="pmTitle">@Tr("pay_salary")</span>
            <button class="modal-close" onclick="closeModal('payModal')">×</button>
        </div>
        <form method="post" id="payForm">
            @Html.AntiForgeryToken()
            <div class="mfg"><label>@Tr("amount") (₹)</label><input name="amount" id="pmAmount" type="number" min="0" step="500" required /></div>
            <div class="mfg"><label>@Tr("payment_mode")</label>
                <select name="paymentMethod">
                    <option value="Cash">@Tr("cash")</option>
                    <option value="Bank Transfer" selected>@Tr("bank_transfer")</option>
                    <option value="UPI">UPI</option>
                </select>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" onclick="closeModal('payModal')">@Tr("cancel")</button>
                <button type="submit" class="btn-action">@Tr("confirm_payment")</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openModal(id) { document.getElementById(id).classList.add('open'); }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }
    document.querySelectorAll('.modal-overlay').forEach(el => {
        el.addEventListener('click', e => { if (e.target === el) closeModal(el.id); });
    });
    function openEditModal(empId, name, email, dept, salary) {
        document.getElementById('ueTitle').textContent = '@Tr("update_employee"): ' + empId;
        document.getElementById('editEmpForm').action = '/Employee/Edit/' + empId;
        document.getElementById('ueName').value = name;
        document.getElementById('ueEmail').value = email;
        document.getElementById('ueDept').value = dept;
        document.getElementById('ueSalary').value = salary;
        openModal('updateEmpModal');
    }
    function openPayModal(empId, name, salary) {
        document.getElementById('pmTitle').textContent = '@Tr("pay_salary"): ' + name;
        document.getElementById('payForm').action = '/Employee/PaySalary/' + empId;
        document.getElementById('pmAmount').value = salary;
        openModal('payModal');
    }
</script>
