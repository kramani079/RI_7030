@{
    var currentPage = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>RI_7030 - @ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>

    <div class="dashboard">

        <!-- SIDEBAR -->
        <div class="sidebar">
            <div class="brand">RI</div>

            <ul>
                <li class="@(currentPage == "Home" ? "active" : "")">
                    <a href="/">🏠 Home</a>
                </li>
                <li class="@(currentPage == "Order" ? "active" : "")">
                    <a href="/Order">📋 Orders</a>
                </li>
                <li class="@(currentPage == "Inventory" ? "active" : "")">
                    <a href="/Inventory">📦 Inventory</a>
                </li>
                <li class="@(currentPage == "Employee" ? "active" : "")">
                    <a href="/Employee">👥 Employees</a>
                </li>
                <li class="@(currentPage == "Transaction" ? "active" : "")">
                    <a href="/Transaction">💳 Transactions</a>
                </li>
            </ul>
        </div>

        <!-- MAIN -->
        <div class="main-content">

            <!-- TOPBAR -->
            <div class="topbar">
                <span style="color:rgba(255,255,255,0.9);font-size:13px;font-weight:600;">
                    Welcome, @(Context.Session.GetString("Name")?.ToUpper() ?? "USER")
                    <span style="margin-left:10px;padding:3px 12px;background:rgba(255,255,255,0.2);border-radius:12px;font-size:11px;font-weight:700;">
                        @(Context.Session.GetString("Role") ?? "")
                    </span>
                </span>
                <div style="display:flex;align-items:center;gap:14px;margin-left:auto;">
                    <a asp-controller="Profile" asp-action="Index"
                       style="background:rgba(255,255,255,0.15);color:#fff;border:1px solid rgba(255,255,255,0.35);padding:6px 16px;border-radius:8px;font-size:12px;font-weight:600;text-decoration:none;transition:background 0.2s;">
                        Profile
                    </a>
                    <a href="/Login/Logout"
                       style="background:rgba(255,255,255,0.9);color:#1a6d99;padding:6px 18px;border-radius:8px;font-size:12px;font-weight:700;text-decoration:none;border:none;transition:all 0.2s;">
                        Logout
                    </a>
                </div>
            </div>

            <!-- PAGE CONTENT -->
            <div class="page-container">
                @RenderBody()
            </div>

        </div>

    </div>

</body>
</html>