<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>RI_7030 - @ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>

    <div class="dashboard">

        <!-- SIDEBAR -->
        <div class="sidebar">
            <div class="brand">RI</div>

            <ul>
                <li><a href="/">🏠 Home</a></li>
                <li><a href="/Order">📋 Orders</a></li>
                <li><a href="/Inventory">📦 Inventory</a></li>
                <li><a href="/Employee">👥 Employees</a></li>
                <li><a href="/Transaction">💳 Transactions</a></li>
            </ul>
        </div>

        <!-- MAIN -->
        <div class="main-content">

            <!-- TOPBAR -->
            <div class="topbar">
                <span style="color:rgba(255,255,255,0.75);font-size:13px;font-weight:500;">
                    👋 Welcome, @(Context.Session.GetString("Name") ?? "User")
                    <span style="margin-left:8px;padding:2px 10px;background:rgba(255,255,255,0.2);border-radius:12px;font-size:11px;">
                        @(Context.Session.GetString("Role") ?? "")
                    </span>
                </span>
                <div style="display:flex;align-items:center;gap:16px;margin-left:auto;">
                    <a class="profile" asp-controller="Profile" asp-action="Index" style="font-size:20px;text-decoration:none;">👤</a>
                    <a href="/Login/Logout" style="color:rgba(255,255,255,0.8);font-size:12px;font-weight:600;text-decoration:none;border:1px solid rgba(255,255,255,0.4);padding:5px 14px;border-radius:8px;">
                        Logout
                    </a>
                </div>
            </div>

            <!-- PAGE CONTENT -->
            <div class="page-container">
                @RenderBody()
            </div>

        </div>

    </div>

</body>
</html>