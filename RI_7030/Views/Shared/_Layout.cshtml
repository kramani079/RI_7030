@{
    var role = Context.Session.GetString("Role") ?? "";
    var name = Context.Session.GetString("Name") ?? "User";
    var isAdmin = role == "Admin";
    var T = ViewBag.T as Dictionary<string, string> ?? new Dictionary<string, string>();
    var lang = ViewBag.Lang as string ?? "en";
    string Tr(string key) => T.TryGetValue(key, out var v) ? v : key;
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] – Rajesh Industries</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/dashboard.css" />
</head>
<body>
    <div class="dashboard">

        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="brand">RI</div>
            <ul>
                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <a href="/Home">🏠 @Tr("nav_home")</a>
                </li>
                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")">
                    <a href="/Order">📋 @Tr("nav_orders")</a>
                </li>
                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventory" ? "active" : "")">
                    <a href="/Inventory">📦 @Tr("nav_inventory")</a>
                </li>
                @if (isAdmin)
                {
                    <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Employee" ? "active" : "")">
                        <a href="/Employee">👥 @Tr("nav_employees")</a>
                    </li>
                }
                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Transaction" ? "active" : "")">
                    <a href="/Transaction">💰 @Tr("nav_transactions")</a>
                </li>
                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Salary" ? "active" : "")">
                    <a href="/Salary">💵 @Tr("nav_salary")</a>
                </li>

            </ul>
        </aside>

        <!-- Main Content -->
        <div class="main-content">

            <!-- Topbar -->
            <div class="topbar">
                <div style="flex:1;font-size:14px;font-weight:600;">
                    @Tr("welcome"), @name
                </div>

                <!-- Language Toggle -->
                <form method="post" action="/Profile/SetLanguage" style="display:inline;margin-right:18px;">
                    @Html.AntiForgeryToken()
                    @if (lang == "en")
                    {
                        <input type="hidden" name="lang" value="gu" />
                        <button type="submit" style="background:rgba(255,255,255,.18);color:#fff;border:1px solid rgba(255,255,255,.4);padding:5px 14px;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;" title="Switch to Gujarati">
                            ગુજ
                        </button>
                    }
                    else
                    {
                        <input type="hidden" name="lang" value="en" />
                        <button type="submit" style="background:rgba(255,255,255,.18);color:#fff;border:1px solid rgba(255,255,255,.4);padding:5px 14px;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;" title="Switch to English">
                            ENG
                        </button>
                    }
                </form>

                <a href="/Profile" style="color:rgba(255,255,255,.8);text-decoration:none;font-size:13px;margin-right:16px;">👤 @Tr("nav_profile")</a>
                <a href="/Login/Logout" style="color:rgba(255,255,255,.7);text-decoration:none;font-size:12px;">@Tr("nav_logout") →</a>
            </div>

            <!-- Page Content -->
            <div class="page-container">
                @RenderBody()
            </div>

        </div>

    </div>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>