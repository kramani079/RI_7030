@{
    ViewData["Title"] = "Order Details";
    var orderId = ViewBag.OrderId ?? 1;
}

<style>
    .detail-wrapper { max-width: 760px; margin: 0 auto; }
    .back-link { display: inline-flex; align-items: center; gap: 6px; color: #4a8dac; font-size: 13px; font-weight: 600; text-decoration: none; margin-bottom: 18px; }
    .back-link:hover { text-decoration: underline; }

    .order-header-card {
        background: linear-gradient(135deg, #4a8dac 0%, #2c6e8a 100%);
        border-radius: 14px; padding: 24px 30px; margin-bottom: 18px;
        display: flex; justify-content: space-between; align-items: flex-start;
        box-shadow: 0 6px 18px rgba(74,141,172,.25);
    }
    .order-header-card .order-id { color: rgba(255,255,255,.7); font-size: 13px; margin-bottom: 4px; }
    .order-header-card h4 { color: #fff; font-size: 22px; font-weight: 800; margin: 0 0 6px; }
    .order-header-card .sub { color: rgba(255,255,255,.8); font-size: 13px; }

    .detail-card { background: #fff; border-radius: 12px; padding: 22px 26px; box-shadow: 0 4px 12px rgba(0,0,0,.07); margin-bottom: 16px; }
    .detail-card .sec-title { font-size: 11px; font-weight: 800; color: #aaa; text-transform: uppercase; letter-spacing: .8px; margin-bottom: 14px; padding-bottom: 8px; border-bottom: 1px solid #f0f0f0; }
    .detail-row { display: flex; justify-content: space-between; padding: 9px 0; border-bottom: 1px solid #f5f5f5; font-size: 13px; }
    .detail-row:last-child { border-bottom: none; }
    .detail-row .lbl { color: #888; font-weight: 600; }
    .detail-row .val { color: #1a1a2e; font-weight: 700; text-align: right; }

    /* Production tracker */
    .stage-tracker { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; }
    .stage-item { border-radius: 10px; padding: 14px 10px; text-align: center; font-size: 12px; font-weight: 700; }
    .stage-done    { background: #eafaf1; color: #1e8449; border: 2px solid #27ae60; }
    .stage-pending { background: #f9f9fb; color: #bbb; border: 2px solid #e8e8e8; }
    .stage-icon { font-size: 22px; display: block; margin-bottom: 6px; }
    .stage-check { font-size: 14px; display: block; margin-top: 4px; }

    /* Progress */
    .big-progress { background: #eee; border-radius: 20px; height: 12px; overflow: hidden; margin: 10px 0 6px; }
    .big-progress-fill { height: 100%; border-radius: 20px; background: linear-gradient(90deg,#3498db,#27ae60); transition: width .4s; }

    /* Action buttons */
    .action-row { display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap; }
    .btn-edit-full { background: #4a8dac; color: #fff; border: none; padding: 10px 28px; border-radius: 8px; font-size: 14px; font-weight: 700; cursor: pointer; text-decoration: none; }
    .btn-edit-full:hover { background: #3a7a98; color: #fff; }
    .btn-del-full  { background: #fdedec; color: #c0392b; border: none; padding: 10px 28px; border-radius: 8px; font-size: 14px; font-weight: 700; cursor: pointer; text-decoration: none; }
    .btn-del-full:hover { background: #fcd4d1; }

    .badge { display:inline-block; padding:4px 14px; border-radius:20px; font-size:12px; font-weight:700; }
    .badge-prod     { background:#e8f4fd; color:#2980b9; }
    .badge-pending  { background:#fff8e1; color:#856404; }
    .badge-ready    { background:#eafaf1; color:#1e8449; }
    .badge-delivered{ background:#eee; color:#555; }

    @@media(max-width:600px) { .stage-tracker { grid-template-columns:repeat(2,1fr); } }
</style>

<div class="detail-wrapper">
    <a href="/Order" class="back-link">← Back to Orders</a>

    <!-- Header -->
    <div class="order-header-card">
        <div>
            <div class="order-id">Order #ORD-10@orderId</div>
            <h4>Gold Chain</h4>
            <div class="sub">📅 Placed: Feb 20, 2026 &nbsp;|&nbsp; ⏰ Due: Feb 28, 2026</div>
        </div>
        <span class="badge badge-prod" style="font-size:13px;padding:6px 18px;">In Production</span>
    </div>

    <!-- Customer -->
    <div class="detail-card">
        <div class="sec-title">👤 Customer Information</div>
        <div class="detail-row"><span class="lbl">Customer Name</span><span class="val">Mahesh Patel</span></div>
        <div class="detail-row"><span class="lbl">Email</span><span class="val">mahesh@gmail.com</span></div>
        <div class="detail-row"><span class="lbl">Phone</span><span class="val">+91 98765 43210</span></div>
    </div>

    <!-- Order -->
    <div class="detail-card">
        <div class="sec-title">📦 Order Information</div>
        <div class="detail-row"><span class="lbl">Product</span><span class="val">Gold Chain</span></div>
        <div class="detail-row"><span class="lbl">Quantity</span><span class="val">50 pcs</span></div>
        <div class="detail-row"><span class="lbl">Unit Price</span><span class="val">₹5,000</span></div>
        <div class="detail-row"><span class="lbl">Total Amount</span><span class="val" style="color:#27ae60;font-size:16px;">₹2,50,000</span></div>
        <div class="detail-row"><span class="lbl">Notes</span><span class="val" style="color:#aaa;">—</span></div>
    </div>

    <!-- Production -->
    <div class="detail-card">
        <div class="sec-title">⚙ Production Progress</div>
        <div class="big-progress"><div class="big-progress-fill" style="width:75%"></div></div>
        <div style="font-size:13px;font-weight:700;color:#555;margin-bottom:14px;">75% Complete — Next: Stage 4 Packaging</div>
        <div class="stage-tracker">
            <div class="stage-item stage-done">
                <span class="stage-icon">🔨</span>
                Stage 1<br/>Casting
                <span class="stage-check">✔ Done</span>
            </div>
            <div class="stage-item stage-done">
                <span class="stage-icon">✨</span>
                Stage 2<br/>Finishing
                <span class="stage-check">✔ Done</span>
            </div>
            <div class="stage-item stage-done">
                <span class="stage-icon">🥇</span>
                Stage 3<br/>Gold Plating
                <span class="stage-check">✔ Done</span>
            </div>
            <div class="stage-item stage-pending">
                <span class="stage-icon">📦</span>
                Stage 4<br/>Packaging
                <span class="stage-check">⏳ Pending</span>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="action-row">
        <a href="/Order/Edit/@orderId"   class="btn-edit-full">✏ Edit Order</a>
        <a href="/Transaction?tab=sell"  class="btn-edit-full" style="background:#27ae60;">💰 Record Sale</a>
        <a href="/Order/Delete/@orderId" class="btn-del-full"  onclick="return confirm('Delete this order?')">🗑 Delete</a>
    </div>
</div>
