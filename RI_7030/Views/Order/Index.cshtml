<!-- ── Edit Order Modal ──────────────────────────── -->
<div class="modal-overlay" id="editOrderModal">
    <div class="modal-box md-large">
        <div class="modal-title">
            <span>Edit Order</span>
            <button class="modal-close" onclick="closeModal('editOrderModal')">×</button>
        </div>
        <div class="modal-grid">
            <div class="mfg"><label>Customer Name</label><input type="text" id="eoCust" /></div>
            <div class="mfg"><label>Email</label><input type="email" id="eoEmail" /></div>
            <div class="mfg"><label>Product ID</label><input type="text" id="eoPid" /></div>
            <div class="mfg"><label>Product Name</label><input type="text" id="eoPname" /></div>
            <div class="mfg"><label>Quantity</label><input type="number" id="eoQty" oninput="calcEditOrderTotal()" /></div>
            <div class="mfg"><label>Unit Price (₹)</label><input type="number" id="eoUp" oninput="calcEditOrderTotal()" /></div>
            <div class="mfg"><label>Total Amount (₹)</label><input type="text" id="eoTotal" readonly /></div>
            <div class="mfg"><label>Due Date</label><input type="date" id="eoDue" /></div>
            <div class="mfg" style="grid-column: 1 / -1;"><label>Status</label>
                <select id="eoStatus">
                    <option value="Pending">Pending</option>
                    <option value="InProduction">In Production</option>
                    <option value="Ready">Ready</option>
                    <option value="Delivered">Delivered</option>
                </select>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('editOrderModal')">Cancel</button>
            <button class="btn-action" onclick="closeModal('editOrderModal')">Save Order</button>
        </div>
    </div>
</div>

<script>
    function openModal(id) { document.getElementById(id).classList.add('open'); }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }

    function openDetailsModal(id, cust, email, pName, pId, qty, up, total, due, status, prog) {
        document.getElementById('vdTitle').textContent = 'Order Details: ' + id;
        document.getElementById('vdCust').textContent = cust;
        document.getElementById('vdEmail').textContent = email;
        document.getElementById('vdProduct').textContent = pName + ' (' + pId + ')';
        document.getElementById('vdQty').textContent = qty;
        document.getElementById('vdUp').textContent = '₹' + up.toLocaleString('en-IN');
        document.getElementById('vdTotal').textContent = '₹' + total.toLocaleString('en-IN');
        document.getElementById('vdDue').textContent = due;
        document.getElementById('vdStatus').textContent = status;
        document.getElementById('vdProg').textContent = prog;
        openModal('orderDetailsModal');
    }

    function openEditModal(id, cust, email, pId, pName, qty, up, total, due, status) {
        document.getElementById('eoCust').value = cust;
        document.getElementById('eoEmail').value = email;
        document.getElementById('eoPid').value = pId;
        document.getElementById('eoPname').value = pName;
        document.getElementById('eoQty').value = qty;
        document.getElementById('eoUp').value = up;
        document.getElementById('eoTotal').value = total.toLocaleString('en-IN');
        document.getElementById('eoDue').value = due;
        document.getElementById('eoStatus').value = status;
        openModal('editOrderModal');
    }

    function calcEditOrderTotal() {
        const q = parseFloat(document.getElementById('eoQty').value) || 0;
        const u = parseFloat(document.getElementById('eoUp').value) || 0;
        document.getElementById('eoTotal').value = (q * u).toLocaleString('en-IN');
    }

    document.querySelectorAll('.modal-overlay').forEach(el => {
        el.addEventListener('click', e => { if (e.target === el) closeModal(el.id); });
    });
    function filterOrders() {
        const q = document.getElementById('orderSearch').value.toLowerCase();
        document.querySelectorAll('#orderTable tbody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }

    function filterStatus(status, el) {
        // Update active tab
        document.querySelectorAll('.ftab').forEach(t => t.classList.remove('active'));
        el.classList.add('active');
        // Filter rows
        document.querySelectorAll('#orderTable tbody tr').forEach(row => {
            row.style.display = (status === 'all' || row.dataset.status === status) ? '' : 'none';
        });
        return false;
    }
</script>
