@{
    ViewData["Title"] = "Orders";
}

<style>
    .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
    .page-header h5 { margin:0; font-size:18px; font-weight:700; color:#1a1a2e; }

    .btn-primary-sm {
        background:#4a8dac; color:#fff; border:none; padding:8px 20px;
        border-radius:8px; font-size:13px; font-weight:600; cursor:pointer;
        text-decoration:none; display:inline-flex; align-items:center; gap:6px;
    }
    .btn-primary-sm:hover { background:#3a7a98; color:#fff; }

    .search-bar { display:flex; gap:10px; margin-bottom:18px; }
    .search-bar input {
        flex:1; padding:8px 14px; border:1px solid #ddd; border-radius:8px;
        font-size:13px; background:#f9f9fb; outline:none;
    }
    .search-bar input:focus { border-color:#4a8dac; }

    /* Filter tabs */
    .filter-tabs { display:flex; gap:8px; margin-bottom:18px; flex-wrap:wrap; }
    .ftab {
        padding:5px 14px; border-radius:20px; font-size:12px; font-weight:600;
        border:1.5px solid #e0e6ed; background:#fff; color:#666; cursor:pointer; text-decoration:none;
        transition: all .15s;
    }
    .ftab:hover, .ftab.active { background:#4a8dac; color:#fff; border-color:#4a8dac; }
    .ftab.all    { border-color:#4a8dac; }
    .ftab.pending { border-color:#f39c12; }
    .ftab.prod   { border-color:#3498db; }
    .ftab.ready  { border-color:#27ae60; }
    .ftab.done   { border-color:#aaa; }

    /* Table */
    .order-table { width:100%; border-collapse:collapse; font-size:13px; }
    .order-table thead th {
        background:#f0f4f8; padding:10px 14px; text-align:left;
        font-weight:700; color:#555; border-bottom:2px solid #e0e6ed;
    }
    .order-table tbody td {
        padding:11px 14px; border-bottom:1px solid #f0f0f0;
        color:#333; vertical-align:middle;
    }
    .order-table tbody tr:hover { background:#f7fafc; }

    /* Progress bar */
    .prog-wrap { display:flex; align-items:center; gap:8px; }
    .prog-bg { background:#eee; border-radius:20px; height:7px; width:80px; overflow:hidden; }
    .prog-fill { height:100%; border-radius:20px; background:linear-gradient(90deg,#3498db,#27ae60); }
    .prog-pct { font-size:11px; font-weight:700; color:#555; }

    /* Stage dots */
    .stage-dots { display:flex; gap:4px; }
    .sdot {
        width:18px; height:18px; border-radius:50%;
        font-size:8px; font-weight:700; color:#fff;
        display:flex; align-items:center; justify-content:center;
    }
    .sdot-done    { background:#27ae60; }
    .sdot-pending { background:#ddd; color:#999; }

    /* Status badges */
    .badge { display:inline-block; padding:3px 11px; border-radius:20px; font-size:11px; font-weight:700; }
    .badge-pending  { background:#fff8e1; color:#856404; }
    .badge-prod     { background:#e8f4fd; color:#2980b9; }
    .badge-ready    { background:#eafaf1; color:#1e8449; }
    .badge-delivered{ background:#e8f4fd; color:#555; }
    .badge-cancelled{ background:#fdecea; color:#842029; }
    .badge-overdue  { background:#fdecea; color:#c0392b; }

    /* Action btns */
    .action-btn { padding:4px 12px; border-radius:6px; font-size:11px; font-weight:600; border:none; cursor:pointer; text-decoration:none; }
    .btn-view   { background:#eaf4fb; color:#2980b9; }
    .btn-edit   { background:#f9f9fb; color:#555; margin-left:4px; }
    .btn-delete { background:#fdedec; color:#c0392b; margin-left:4px; }

    /* Success toast */
    .toast-success {
        background:#d1f5e0; color:#155724; padding:10px 16px;
        border-radius:8px; margin-bottom:16px; font-size:13px; font-weight:600;
    }

    /* Floating add */
    .floating-add {
        position:fixed; bottom:36px; right:36px;
        background:#4a8dac; color:#fff; width:50px; height:50px;
        border-radius:50%; font-size:26px;
        display:flex; align-items:center; justify-content:center;
        box-shadow:0 6px 18px rgba(74,141,172,.4);
        text-decoration:none; transition:transform .2s;
    }
    .floating-add:hover { transform:scale(1.1); color:#fff; }
</style>

