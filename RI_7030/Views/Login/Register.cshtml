@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Create New Account - RI</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f2f8fc;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .register-card {
            background: #ffffff;
            width: 480px;
            max-width: 100%;
            border-radius: 12px;
            box-shadow: 0 4px 30px rgba(0,0,0,0.06);
            padding: 40px;
        }

        .register-title {
            text-align: center;
            font-size: 20px;
            font-weight: 700;
            color: #1a3a5c;
            margin-bottom: 24px;
        }

        .divider {
            height: 1px;
            background: #eef2f6;
            margin-bottom: 24px;
        }

        .section-label {
            font-size: 13px;
            font-weight: 600;
            color: #555;
            margin-bottom: 12px;
            display: block;
        }

        .form-group {
            margin-bottom: 14px;
        }

        .form-control {
            width: 100%;
            padding: 11px 14px;
            border: 1px solid #dde4ec;
            border-radius: 6px;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            background: #f8f9fb;
            color: #333;
            outline: none;
            transition: all 0.2s;
        }
        .form-control::placeholder { color: #aab4c0; }
        .form-control:focus {
            background: #fff;
            border-color: #4a8dac;
            box-shadow: 0 0 0 3px rgba(74,141,172,0.1);
        }

        .radio-group {
            display: flex;
            gap: 24px;
            margin-bottom: 18px;
            align-items: center;
        }

        .radio-label {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            font-weight: 500;
            color: #333;
            cursor: pointer;
        }
        .radio-label input[type="radio"] {
            appearance: none;
            width: 18px;
            height: 18px;
            border: 2px solid #aab4c0;
            border-radius: 50%;
            display: grid;
            place-content: center;
            cursor: pointer;
        }
        .radio-label input[type="radio"]::before {
            content: "";
            width: 10px;
            height: 10px;
            border-radius: 50%;
            transform: scale(0);
            transition: 0.1s transform;
            box-shadow: inset 1em 1em #2b8bbd;
        }
        .radio-label input[type="radio"]:checked {
            border-color: #2b8bbd;
        }
        .radio-label input[type="radio"]:checked::before {
            transform: scale(1);
        }

        .btn-submit {
            width: 80%;
            display: block;
            margin: 28px auto 16px;
            padding: 12px;
            border-radius: 20px;
            background: #3996b8;
            color: #fff;
            border: none;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
        }
        .btn-submit:hover { background: #2f7e9c; }

        .form-footer {
            text-align: center;
            font-size: 12.5px;
            color: #777;
        }
        .form-footer a {
            color: #3996b8;
            text-decoration: none;
            font-weight: 500;
        }
        .form-footer a:hover { text-decoration: underline; }

        .error-msg {
            background: #fdf0ef; color: #c0392b; font-size: 12.5px; font-weight: 500;
            padding: 10px 14px; border-radius: 6px; margin-bottom: 14px; border: 1px solid #f5c6cb;
        }
    </style>
</head>
<body>

    <div class="register-card">
        <div class="register-title">Create New Account</div>
        <div class="divider"></div>

        <form method="post" asp-action="Register" asp-controller="Login">
            @Html.AntiForgeryToken()

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="error-msg">@ViewBag.ErrorMessage</div>
            }

            <span class="section-label">Account Information</span>

            <div class="form-group"><input type="text" class="form-control" name="fullName" placeholder="Full Name *" required /></div>
            <div class="form-group"><input type="email" class="form-control" name="email" placeholder="Email ID *" required /></div>
            <div class="form-group"><input type="text" class="form-control" name="mobile" placeholder="Mobile No *" required /></div>
            <div class="form-group"><input type="text" class="form-control" name="address" placeholder="Address *" required /></div>
            <div class="form-group"><input type="password" class="form-control" name="password" placeholder="Password *" required /></div>
            <div class="form-group"><input type="password" class="form-control" name="confirmPassword" placeholder="Confirm Password *" required /></div>

            <div class="divider" style="margin-top: 24px;"></div>

            <span class="section-label">Account Type</span>
            <div class="radio-group">
                <label class="radio-label">
                    <input type="radio" name="accountType" value="Admin" onclick="toggleEmp(false)" />
                    Admin
                </label>
                <label class="radio-label">
                    <input type="radio" name="accountType" value="Employee" onclick="toggleEmp(true)" checked />
                    Employee
                </label>
            </div>

            <div id="empSection">
                <span class="section-label">Employee Type</span>
                <div class="form-group">
                    <select class="form-control" name="employeeType">
                        <option value="Casting">Casting</option>
                        <option value="Finishing Touch">Finishing Touch</option>
                        <option value="Gold Plating">Gold Plating</option>
                        <option value="Packaging">Packaging</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="btn-submit">Complete Registration</button>
            <div class="form-footer">
                Already have an account? <a href="/Login">Login here</a>
            </div>
        </form>
    </div>

    <script>
        function toggleEmp(show) {
            document.getElementById('empSection').style.display = show ? 'block' : 'none';
        }
        // Initialize state
        toggleEmp(document.querySelector('input[name="accountType"][value="Employee"]').checked);
    </script>
</body>
</html>