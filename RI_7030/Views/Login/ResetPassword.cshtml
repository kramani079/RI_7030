@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
    var token = Context.Request.Query["token"].ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Reset Password – Rajesh Industries</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #1a6d99 0%, #1a1a2e 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .card { background: #fff; border-radius: 16px; padding: 48px 44px; width: 100%; max-width: 420px; box-shadow: 0 24px 60px rgba(0,0,0,0.2); }
        .brand { font-size: 28px; font-weight: 800; color: #1a6d99; letter-spacing: -1px; margin-bottom: 8px; }
        .subtitle { color: #888; font-size: 14px; margin-bottom: 36px; }
        .fg { margin-bottom: 20px; position: relative; }
        .fg label { display: block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #666; margin-bottom: 8px; }
        .fg input { width: 100%; padding: 12px 40px 12px 16px; border: 1.5px solid #dde1e7; border-radius: 10px; font-size: 14px; font-family: 'Inter', sans-serif; outline: none; }
        .fg input:focus { border-color: #2b8bbd; box-shadow: 0 0 0 3px rgba(43,139,189,.1); }
        .eye { position: absolute; right: 12px; top: 34px; cursor: pointer; color: #aaa; font-size: 16px; user-select: none; }
        .btn-submit { width: 100%; padding: 14px; background: linear-gradient(135deg, #2b8bbd, #1a6d99); color: #fff; border: none; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; margin-top: 6px; }
        .btn-submit:hover { opacity: .9; }
        .alert-success { background: #d1f5e0; color: #155724; padding: 12px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; margin-bottom: 20px; }
        .alert-danger  { background: #fdecea; color: #842029; padding: 12px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; margin-bottom: 20px; }
        .back-link { display: block; text-align: center; margin-top: 20px; color: #4a8dac; font-size: 13px; font-weight: 600; text-decoration: none; }
    </style>
</head>
<body>
    <div class="card">
        <div class="brand">RI</div>
        <div class="subtitle">Enter your new password below.</div>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert-danger">✗ @ViewBag.ErrorMessage</div>
        }
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="alert-success">✓ @ViewBag.SuccessMessage</div>
            <a href="/Login" class="back-link">→ Go to Login</a>
        }
        else
        {
            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="token" value="@token" />

                <div class="fg">
                    <label>New Password</label>
                    <input name="newPassword" id="np" type="password" placeholder="At least 6 characters" required />
                    <span class="eye" onclick="toggle('np')">👁</span>
                </div>
                <div class="fg">
                    <label>Confirm Password</label>
                    <input name="confirmPassword" id="cnp" type="password" placeholder="Repeat password" required />
                    <span class="eye" onclick="toggle('cnp')">👁</span>
                </div>
                <button type="submit" class="btn-submit">Reset Password</button>
            </form>
        }

        <a href="/Login" class="back-link">← Back to Login</a>
    </div>

    <script>
        function toggle(id) {
            const el = document.getElementById(id);
            el.type = el.type === 'password' ? 'text' : 'password';
        }
    </script>
</body>
</html>
