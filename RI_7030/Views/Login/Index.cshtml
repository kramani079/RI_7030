@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login - RI</title>

    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            background-color: #e5e5e5;
        }

        .top-bar {
            height: 48px;
            background-color: #2b8bbd;
            display: flex;
            align-items: center;
            padding: 0 32px;
            box-sizing: border-box;
        }

        .top-bar .logo {
            width: 40px;
            height: 24px;
            background-color: #ffffff;
            border-radius: 2px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            color: #2b8bbd;
            margin-right: auto;
        }

        .top-bar .nav-links {
            display: flex;
            gap: 32px;
            margin-right: 24px;
        }

        .top-bar .nav-links span {
            width: 40px;
            height: 4px;
            border-radius: 2px;
            background-color: #ffffff;
        }

        .top-bar .search-box {
            width: 160px;
            height: 24px;
            background-color: #ffffff;
            border-radius: 12px;
        }

        .page-wrapper {
            background-color: #f2f8fc;
            min-height: calc(100vh - 48px);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            background-color: #ffffff;
            width: 520px;
            max-width: 90%;
            border-radius: 8px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
            padding: 32px 40px;
            box-sizing: border-box;
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            gap: 24px;
        }

        .login-illustration {
            border-radius: 4px;
            background: linear-gradient(135deg, #f5fbff, #e8f3ff);
            position: relative;
            overflow: hidden;
        }

        .login-illustration::before {
            content: "";
            position: absolute;
            inset: 16px;
            border-radius: 6px;
            border: 2px solid #d0e4ff;
        }

        .login-illustration-inner {
            position: absolute;
            left: 24px;
            bottom: 18px;
            width: 60%;
            height: 45%;
            background: #ffffff;
            border-radius: 4px;
            box-shadow: 0 8px 18px rgba(0, 0, 0, 0.06);
        }

        .login-illustration-person {
            position: absolute;
            left: 50%;
            bottom: 16px;
            transform: translateX(-40%);
            width: 60px;
            height: 90px;
            background-color: #2b8bbd;
            border-radius: 8px;
        }

        .login-illustration-person::before {
            content: "";
            position: absolute;
            top: -24px;
            left: 50%;
            transform: translateX(-50%);
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: #ffd9b3;
        }

        .login-illustration-person::after {
            content: "";
            position: absolute;
            top: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 42px;
            height: 16px;
            border-radius: 8px 8px 0 0;
            background-color: #1c6085;
        }

        .login-header {
            margin-bottom: 24px;
        }

        .login-header h2 {
            margin: 0;
            font-size: 24px;
            font-weight: 600;
            color: #333333;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: block;
            font-size: 12px;
            font-weight: 500;
            color: #555555;
            margin-bottom: 4px;
        }

        .form-control {
            width: 100%;
            padding: 10px 12px;
            font-size: 13px;
            border-radius: 4px;
            border: 1px solid #d0d7de;
            background-color: #f2f2f2;
            box-sizing: border-box;
        }

        .form-control:focus {
            outline: none;
            border-color: #2b8bbd;
            background-color: #ffffff;
            box-shadow: 0 0 0 2px rgba(43, 139, 189, 0.15);
        }

        .btn-login {
            width: 100%;
            border: none;
            border-radius: 20px;
            background-color: #2b8bbd;
            color: #ffffff;
            padding: 10px 0;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 8px;
        }

        .btn-login:hover {
            background-color: #23729b;
        }

        .login-footer {
            margin-top: 16px;
            font-size: 12px;
            color: #777777;
            text-align: center;
        }

        .login-footer a {
            color: #2b8bbd;
            font-weight: 600;
            text-decoration: none;
        }

        .login-footer a:hover {
            text-decoration: underline;
        }

        .error-message {
            color: #c0392b;
            font-size: 12px;
            margin-bottom: 8px;
        }

        @@media (max-width: 720px) {
            .login-card {
                grid-template-columns: 1fr;
                padding: 24px;
            }

            .login-illustration {
                height: 140px;
            }
        }
    </style>
</head>
<body>
    <div style="padding: 16px 32px; color: #777777; font-size: 20px; font-weight: 500;">
        Login
    </div>

    <div class="top-bar">
        <div class="logo">RI</div>
        <div class="nav-links">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
        </div>
        <div class="search-box"></div>
    </div>

    <div class="page-wrapper">
        <div class="login-card">
            <div class="login-illustration">
                <div class="login-illustration-inner"></div>
                <div class="login-illustration-person"></div>
            </div>

            <div>
                <div class="login-header">
                    <h2>Login</h2>
                </div>

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="error-message">@ViewBag.ErrorMessage</div>
                }

                <form asp-action="Index" asp-controller="Account" method="post">
                    <div class="form-group">
                        <label for="email">Email ID</label>
                        <input type="email" id="email" name="email" class="form-control" placeholder="Email ID" />
                    </div>

                    <div class="form-group">
                        <label for="password">Password</label>
                        <input type="password" id="password" name="password" class="form-control" placeholder="Password" />
                    </div>

                    <button type="submit" class="btn-login">Login</button>
                </form>

                <div class="login-footer">
                    New user?
                    <a href="#">Register</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

