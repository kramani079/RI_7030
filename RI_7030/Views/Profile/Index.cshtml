@{
    ViewData["Title"] = "Profile";

    // Data corresponding to the "My Profile" screenshot.
    var fname = "KRISH";
    var lname = "RAMANI";
    var fullName = $"{fname} {lname}";
    var initials = "KR";
    var role = "Admin";
    var location = "Surat, Gujarat, India";
    var email = "kramani079@rku.ac.in";
    var phone = "+919714152259";
    var bio = "Admin";
    var country = "India";
    var cityState = "Surat, Gujarat";
    var postalCode = "395003";
    var taxId = "GSTIN1234567";
}

<style>
    .profile-page {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px 0;
        font-family: 'Inter', sans-serif;
    }

    .prof-title {
        font-size: 16px;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 24px;
    }

    .prof-card {
        background: #fff;
        border-radius: 12px;
        padding: 24px 32px;
        box-shadow: 0 4px 20px rgba(0,0,0,.04);
        margin-bottom: 24px;
        position: relative;
    }

    .prof-header {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .prof-avatar {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #3996b8;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        font-weight: 700;
        color: #fff;
    }

    .prof-info h4 {
        margin: 0 0 4px;
        font-size: 16px;
        font-weight: 700;
        color: #1a1a2e;
        text-transform: uppercase;
    }

    .prof-info .sub {
        font-size: 12px;
        color: #666;
        margin-bottom: 2px;
    }

    .edit-btn {
        position: absolute;
        top: 24px;
        right: 32px;
        background: #fff;
        color: #555;
        border: 1px solid #dde4ec;
        padding: 6px 14px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: background .2s;
    }
    .edit-btn:hover { background: #f4f6fb; }

    .sec-title {
        font-size: 14px;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 20px;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .detail-item label {
        font-size: 11px;
        font-weight: 500;
        color: #888;
    }
    .detail-item .val {
        font-size: 13px;
        font-weight: 600;
        color: #1a1a2e;
    }

    @@media (max-width: 600px) {
        .detail-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="profile-page">
    <div class="prof-title">My Profile</div>

    <!-- Header Card -->
    <div class="prof-card">
        <a href="#" class="edit-btn">Edit ✏</a>
        <div class="prof-header">
            <div class="prof-avatar">@initials</div>
            <div class="prof-info">
                <h4>@fullName</h4>
                <div class="sub">@role</div>
                <div class="sub">@location</div>
            </div>
        </div>
    </div>

    <!-- Personal Info Card -->
    <div class="prof-card">
        <a href="#" class="edit-btn">Edit ✏</a>
        <div class="sec-title">Personal Information</div>
        <div class="detail-grid">
            <div class="detail-item">
                <label>First Name</label>
                <div class="val">@fname</div>
            </div>
            <div class="detail-item">
                <label>Last Name</label>
                <div class="val">@lname</div>
            </div>
            <div class="detail-item">
                <label>Email address</label>
                <div class="val">@email</div>
            </div>
            <div class="detail-item">
                <label>Phone</label>
                <div class="val">@phone</div>
            </div>
            <div class="detail-item" style="grid-column: 1 / -1;">
                <label>Bio</label>
                <div class="val">@bio</div>
            </div>
        </div>
    </div>

    <!-- Address Card -->
    <div class="prof-card">
        <a href="#" class="edit-btn">Edit ✏</a>
        <div class="sec-title">Address</div>
        <div class="detail-grid">
            <div class="detail-item">
                <label>Country</label>
                <div class="val">@country</div>
            </div>
            <div class="detail-item">
                <label>City / State</label>
                <div class="val">@cityState</div>
            </div>
            <div class="detail-item">
                <label>Postal Code</label>
                <div class="val">@postalCode</div>
            </div>
            <div class="detail-item">
                <label>TAX ID</label>
                <div class="val">@taxId</div>
            </div>
        </div>
    </div>

</div>
